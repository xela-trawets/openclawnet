@* Channel Configuration Panel — Per-job delivery channel selection *@

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-broadcast me-2"></i>Delivery Channels</h5>
        @if (_saving)
        {
            <span class="spinner-border spinner-border-sm text-primary"></span>
        }
        else if (_saveSuccess)
        {
            <span class="text-success small"><i class="bi bi-check-circle me-1"></i>Saved</span>
        }
        else if (!string.IsNullOrEmpty(_errorMessage))
        {
            <span class="text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>Error</span>
        }
    </div>
    <div class="card-body">
        @if (_loading)
        {
            <div class="text-center py-3"><div class="spinner-border text-primary"></div></div>
        }
        else
        {
            <p class="text-muted small mb-3">Configure which channels this job delivers to on completion.</p>
            
            @foreach (var channel in _channels)
            {
                <div class="border rounded p-3 mb-3">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" 
                               type="checkbox" 
                               id="channel-@channel.Type"
                               checked="@channel.IsEnabled"
                               @onchange="@(e => OnToggleChannel(channel, (bool)e.Value!))" />
                        <label class="form-check-label fw-bold" for="channel-@channel.Type">
                            @GetChannelIcon(channel.Type) @channel.Type
                        </label>
                    </div>
                    
                    @if (channel.IsEnabled)
                    {
                        <div class="mt-2">
                            <label class="form-label small text-muted">Configuration (JSON)</label>
                            <textarea class="form-control form-control-sm font-monospace @(_validationErrors.ContainsKey(channel.Type) ? "is-invalid" : "")"
                                      rows="3"
                                      placeholder='@GetChannelPlaceholder(channel.Type)'
                                      @bind="channel.Config"
                                      @bind:event="oninput"
                                      @onblur="@(() => OnConfigBlur(channel))"></textarea>
                            @if (_validationErrors.TryGetValue(channel.Type, out var error))
                            {
                                <div class="invalid-feedback d-block">@error</div>
                            }
                            <div class="form-text">
                                @GetChannelHint(channel.Type)
                            </div>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@_errorMessage
                    <button type="button" class="btn-close" @onclick="ClearError"></button>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public Guid? JobId { get; set; }
    [Inject] private IHttpClientFactory HttpClientFactory { get; set; } = null!;

    private bool _loading = true;
    private bool _saving;
    private bool _saveSuccess;
    private string? _errorMessage;
    private List<ChannelConfigViewModel> _channels = new();
    private Dictionary<string, string> _validationErrors = new();

    protected override async Task OnParametersSetAsync()
    {
        if (JobId.HasValue)
            await LoadChannelConfigs();
    }

    private async Task LoadChannelConfigs()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            var client = HttpClientFactory.CreateClient("scheduler-self");
            var response = await client.GetAsync($"/api/jobs/{JobId}/channels");
            
            if (response.IsSuccessStatusCode)
            {
                var configs = await response.Content.ReadFromJsonAsync<List<JobChannelConfigDto>>() ?? new();
                
                // Initialize with all supported channel types
                var supportedTypes = new[] { "GenericWebhook", "Teams", "Slack" };
                _channels = supportedTypes.Select(type =>
                {
                    var existing = configs.FirstOrDefault(c => c.ChannelType == type);
                    return new ChannelConfigViewModel
                    {
                        Type = type,
                        Config = existing?.ChannelConfig,
                        IsEnabled = existing?.IsEnabled ?? false
                    };
                }).ToList();
            }
            else
            {
                _errorMessage = $"Failed to load channels: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading channels: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnToggleChannel(ChannelConfigViewModel channel, bool isEnabled)
    {
        channel.IsEnabled = isEnabled;
        await SaveChannel(channel);
    }

    private async Task OnConfigBlur(ChannelConfigViewModel channel)
    {
        if (channel.IsEnabled)
        {
            await SaveChannel(channel);
        }
    }

    private async Task SaveChannel(ChannelConfigViewModel channel)
    {
        _saving = true;
        _saveSuccess = false;
        _validationErrors.Remove(channel.Type);
        
        try
        {
            var client = HttpClientFactory.CreateClient("scheduler-self");
            var request = new UpdateJobChannelConfigRequest(channel.Config, channel.IsEnabled);
            var response = await client.PutAsJsonAsync($"/api/jobs/{JobId}/channels/{channel.Type}", request);
            
            if (response.IsSuccessStatusCode)
            {
                _saveSuccess = true;
                await Task.Delay(2000);
                _saveSuccess = false;
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _validationErrors[channel.Type] = $"Save failed: {response.StatusCode}";
                _errorMessage = errorContent;
            }
        }
        catch (Exception ex)
        {
            _validationErrors[channel.Type] = ex.Message;
            _errorMessage = $"Error saving channel: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ClearError() => _errorMessage = null;

    private static string GetChannelIcon(string type) => type switch
    {
        "GenericWebhook" => "🌐",
        "Teams" => "💬",
        "Slack" => "🔵",
        _ => "📡"
    };

    private static string GetChannelPlaceholder(string type) => type switch
    {
        "GenericWebhook" => "{\"webhookUrl\":\"https://example.com/webhook\"}",
        "Teams" => "{\"serviceUrl\":\"https://smba.trafficmanager.net/...\",\"conversationId\":\"...\"}",
        "Slack" => "{\"webhookUrl\":\"https://hooks.slack.com/services/...\"}",
        _ => "{}"
    };

    private static string GetChannelHint(string type) => type switch
    {
        "GenericWebhook" => "Provide a webhookUrl to POST job artifacts to.",
        "Teams" => "Requires serviceUrl and conversationId from a proactive messaging session.",
        "Slack" => "Provide a Slack incoming webhook URL.",
        _ => "Provide channel-specific JSON configuration."
    };

    private class ChannelConfigViewModel
    {
        public string Type { get; set; } = string.Empty;
        public string? Config { get; set; }
        public bool IsEnabled { get; set; }
    }

    private record JobChannelConfigDto(
        Guid Id,
        Guid JobId,
        string ChannelType,
        string? ChannelConfig,
        bool IsEnabled,
        DateTime CreatedAt,
        DateTime UpdatedAt);

    private record UpdateJobChannelConfigRequest(string? ChannelConfig, bool IsEnabled);
}
