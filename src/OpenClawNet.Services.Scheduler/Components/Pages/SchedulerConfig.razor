@page "/settings"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Settings — OpenClawNet Scheduler</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-gear me-2"></i>Scheduler Settings</h4>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_settings is not null)
{
    <div class="card" style="max-width:540px">
        <div class="card-header">Job Execution Limits</div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-semibold">Max Concurrent Jobs</label>
                <input type="number" class="form-control" min="1" max="20"
                       @bind="_settings.MaxConcurrentJobs" />
                <div class="form-text">How many jobs can run at the same time (1–20).</div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Job Timeout (seconds)</label>
                <input type="number" class="form-control" min="10" max="3600"
                       @bind="_settings.JobTimeoutSeconds" />
                <div class="form-text">A job is forcibly cancelled after this many seconds (10–3600).</div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Poll Interval (seconds)</label>
                <input type="number" class="form-control" min="5" max="3600"
                       @bind="_settings.PollIntervalSeconds" />
                <div class="form-text">How often the scheduler checks for due jobs (5–3600).</div>
            </div>

            @if (_saved)
            {
                <div class="alert alert-success py-1 small"><i class="bi bi-check-circle me-1"></i>Settings saved.</div>
            }
            @if (_saveError is not null)
            {
                <div class="alert alert-danger py-1 small"><i class="bi bi-x-circle me-1"></i>@_saveError</div>
            }
        </div>
        <div class="card-footer">
            <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                @if (_saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="bi bi-save me-1"></i>Save Settings
            </button>
        </div>
    </div>
}

@code {
    private SchedulerSettings? _settings;
    private bool _loading = true;
    private bool _saving;
    private bool _saved;
    private string? _saveError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("scheduler-self");
            _settings = await client.GetFromJsonAsync<SchedulerSettings>("/api/scheduler/settings");
        }
        catch (Exception ex) { _saveError = ex.Message; }
        finally { _loading = false; }
    }

    private async Task Save()
    {
        if (_settings is null) return;
        _saving = true;
        _saved = false;
        _saveError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("scheduler-self");
            var response = await client.PutAsJsonAsync("/api/scheduler/settings", _settings);
            response.EnsureSuccessStatusCode();
            _saved = true;
            await Task.Delay(3000);
            _saved = false;
        }
        catch (Exception ex) { _saveError = ex.Message; }
        finally { _saving = false; }
    }
}
