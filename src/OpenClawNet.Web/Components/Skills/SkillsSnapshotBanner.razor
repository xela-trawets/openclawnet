@using OpenClawNet.Web.Models.Skills
@using OpenClawNet.Web.Services
@implements IAsyncDisposable
@inject SkillsClient SkillsClient

@*
    K-3 hot-reload banner (spec §6 — D-3 polling decision). Polls
    /api/skills/snapshot every 5s, compares to the snapshot id pinned at
    page load. When divergent, shows a Bootstrap warning banner with the
    change summary. Click → Refresh callback (page re-pulls full list).
*@

@if (_changed)
{
    <div class="alert alert-warning d-flex justify-content-between align-items-center mb-3"
         role="alert"
         data-testid="snapshot-banner">
        <div>
            <span class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></span>
            <strong>Skills changed.</strong>
            @if (!string.IsNullOrWhiteSpace(_summary))
            {
                <span> @_summary</span>
            }
        </div>
        <button type="button" class="btn btn-sm btn-warning" @onclick="OnRefreshAsync">
            <span class="bi bi-arrow-clockwise me-1" aria-hidden="true"></span>Refresh
        </button>
    </div>
}

@code {
    /// <summary>Snapshot id pinned by the page at load time. When the live snapshot id differs, we show the banner.</summary>
    [Parameter] public string? PinnedSnapshotId { get; set; }
    /// <summary>Invoked when the user clicks Refresh. The page re-pulls the full list and re-pins.</summary>
    [Parameter] public EventCallback OnRefresh { get; set; }
    /// <summary>Polling interval in ms (default 5000 per D-3). Tests override.</summary>
    [Parameter] public int PollIntervalMs { get; set; } = 5000;

    private CancellationTokenSource? _cts;
    private bool _changed;
    private string? _summary;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        _ = PollLoopAsync(_cts.Token);
        await Task.CompletedTask;
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        // Don't fire immediately — page just loaded and pinned its own snapshot.
        try
        {
            while (!ct.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(PollIntervalMs, ct);
                }
                catch (TaskCanceledException) { return; }

                if (string.IsNullOrEmpty(PinnedSnapshotId)) continue;

                try
                {
                    var snap = await SkillsClient.GetSnapshotAsync(ct);
                    var nowChanged = !string.Equals(snap.Id, PinnedSnapshotId, StringComparison.Ordinal);
                    if (nowChanged != _changed || snap.ChangeSummary != _summary)
                    {
                        _changed = nowChanged;
                        _summary = nowChanged ? snap.ChangeSummary : null;
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch
                {
                    // Gateway hiccup — silent. Next tick retries.
                }
            }
        }
        catch
        {
            // Defensive — keep the page alive even if the polling loop dies.
        }
    }

    private async Task OnRefreshAsync()
    {
        _changed = false;
        _summary = null;
        await OnRefresh.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts is not null)
        {
            _cts.Cancel();
            _cts.Dispose();
            _cts = null;
        }
        await Task.CompletedTask;
    }
}
