@using Microsoft.JSInterop
@using System.Globalization
@using System.Text
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="agent-console" data-testid="agent-console">
    <div class="console-header">
        <button class="btn btn-sm btn-link text-decoration-none p-0" @onclick="ToggleExpand">
            <span class="console-toggle-icon">@(isExpanded ? "▼" : "▶")</span>
            <span class="ms-2">🤖 Agent Activity</span>
            @if (entries.Count > 0)
            {
                <span class="badge bg-secondary ms-2">@entries.Count</span>
            }
        </button>
        <div class="console-actions">
            <button class="btn btn-sm btn-outline-secondary" @onclick="ExportToFile" title="Export full log to a markdown file" data-testid="agent-console-export">
                💾 Export
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CopyToClipboard" title="Copy all logs">
                📋 Copy
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearConsole" title="Clear console">
                🗑️ Clear
            </button>
        </div>
    </div>
    @if (isExpanded)
    {
        <div class="console-body console-body-expanded" @ref="consoleRef">
            @if (entries.Count == 0)
            {
                <div class="text-muted text-center py-3">
                    <small>No agent activity yet. Tool calls and operations will appear here.</small>
                </div>
            }
            else
            {
                var visibleEntries = entries.Take(VisibleMaxEntries);
                @foreach (var entry in visibleEntries)
                {
                    var hasDetails = !string.IsNullOrWhiteSpace(entry.Details);
                    <div class="log-entry log-@entry.Level @(hasDetails ? "log-entry-expandable" : null)"
                         @onclick="() => ToggleEntry(entry)"
                         data-testid="agent-console-entry">
                        <span class="log-chevron">@(hasDetails ? (entry.IsExpanded ? "▼" : "▶") : "")</span>
                        <span class="log-time">[@entry.Timestamp.ToString("HH:mm:ss")]</span>
                        <span class="log-icon">@GetIcon(entry.Level)</span>
                        <span class="log-message">@entry.Message</span>
                    </div>
                    @if (hasDetails && entry.IsExpanded)
                    {
                        <pre class="log-details" data-testid="agent-console-entry-details">@entry.Details</pre>
                    }
                }
                @if (entries.Count > VisibleMaxEntries)
                {
                    <div class="text-muted text-center py-2" style="font-size: 0.75rem;">
                        … and @(entries.Count - VisibleMaxEntries) older entry(s) (included in Export)
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private List<ConsoleEntry> entries = new();
    private bool isExpanded = false;
    private ElementReference consoleRef;
    private const int MaxEntries = 100;
    private const int VisibleMaxEntries = 20;
    private const int VisibleRowsExpanded = 4;

    public Task AddEntry(string message, string level = "info") => AddEntry(message, level, null);

    public async Task AddEntry(string message, string level, string? details)
    {
        entries.Insert(0, new ConsoleEntry
        {
            Message = message,
            Level = level,
            Timestamp = DateTime.Now,
            Details = string.IsNullOrWhiteSpace(details) ? null : details
        });

        if (entries.Count > MaxEntries)
        {
            entries.RemoveAt(entries.Count - 1);
        }

        StateHasChanged();

        // Auto-scroll to top when expanded (newest entries are at index 0)
        if (isExpanded)
        {
            try
            {
                await JS.InvokeVoidAsync("eval", "arguments[0].scrollTop = 0", consoleRef);
            }
            catch
            {
                // JS interop might fail in some contexts
            }
        }
    }

    private void ToggleExpand()
    {
        isExpanded = !isExpanded;
    }

    private void ToggleEntry(ConsoleEntry entry)
    {
        if (string.IsNullOrWhiteSpace(entry.Details)) return;
        entry.IsExpanded = !entry.IsExpanded;
    }

    private void ClearConsole()
    {
        entries.Clear();
    }

    private async Task CopyToClipboard()
    {
        if (entries.Count == 0) return;

        var logText = string.Join("\n", entries
            .OrderByDescending(e => e.Timestamp)
            .Select(e => $"[{e.Timestamp:HH:mm:ss}] {GetIcon(e.Level)} {e.Message}"));

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", logText);
        }
        catch
        {
            // Clipboard API might not be available
        }
    }

    private async Task ExportToFile()
    {
        if (entries.Count == 0) return;

        var ordered = entries.OrderByDescending(e => e.Timestamp).ToList();
        var sb = new StringBuilder();
        sb.AppendLine("# Agent Activity Log");
        sb.AppendLine();
        sb.Append("Exported: ").AppendLine(DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture));
        sb.Append("Total entries: ").AppendLine(ordered.Count.ToString(CultureInfo.InvariantCulture));
        sb.AppendLine();
        sb.AppendLine("---");
        sb.AppendLine();

        foreach (var e in ordered)
        {
            sb.Append("## [").Append(e.Timestamp.ToString("HH:mm:ss")).Append("] ")
              .Append(GetIcon(e.Level)).Append(' ').AppendLine(e.Message);
            sb.AppendLine();
            sb.Append("- **Level:** ").AppendLine(e.Level);
            sb.Append("- **Timestamp:** ").AppendLine(e.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff", CultureInfo.InvariantCulture));
            sb.AppendLine();
            if (!string.IsNullOrWhiteSpace(e.Details))
            {
                sb.AppendLine("<details><summary>Details</summary>");
                sb.AppendLine();
                sb.AppendLine("```");
                sb.AppendLine(e.Details.TrimEnd());
                sb.AppendLine("```");
                sb.AppendLine();
                sb.AppendLine("</details>");
                sb.AppendLine();
            }
        }

        var filename = $"agent-activity-{DateTime.Now:yyyyMMdd-HHmmss}.md";
        try
        {
            await JS.InvokeVoidAsync("consoleExport.download", filename, sb.ToString(), "text/markdown;charset=utf-8");
        }
        catch
        {
            // JS interop unavailable — fall back to clipboard
            try
            {
                await JS.InvokeVoidAsync("navigator.clipboard.writeText", sb.ToString());
            }
            catch
            {
                // give up silently
            }
        }
    }

    private string GetIcon(string level) => level switch
    {
        "error" => "❌",
        "warning" => "⚠️",
        "success" => "✅",
        "tool" => "🔧",
        _ => "ℹ️"
    };

    public async ValueTask DisposeAsync()
    {
        // Cleanup if needed
        await Task.CompletedTask;
    }

    public class ConsoleEntry
    {
        public string Message { get; set; } = string.Empty;
        public string Level { get; set; } = "info";
        public DateTime Timestamp { get; set; }
        public string? Details { get; set; }
        public bool IsExpanded { get; set; }
    }
}
