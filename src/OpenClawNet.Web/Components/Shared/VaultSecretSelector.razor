@using OpenClawNet.Web.Models.Secrets
@using OpenClawNet.Web.Services
@inject SecretsVaultClient VaultClient

<div class="@ContainerClass">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="form-label fw-semibold">@Label</label>
    }
    
    <div class="input-group">
        <select class="form-select @SelectClass"
                value="@Value"
                @onchange="OnValueChanged"
                disabled="@Disabled">
            <option value="">(Enter value directly or select vault reference)</option>
            <optgroup label="Vault References">
                @if (_loading)
                {
                    <option disabled>(Loading secrets…)</option>
                }
                else if (_secrets.Count == 0)
                {
                    <option disabled>(No secrets available)</option>
                }
                else
                {
                    @foreach (var secret in _secrets)
                    {
                        var vaultRef = $"vault://{secret.Name}";
                        <option value="@vaultRef">
                            @secret.Name@(string.IsNullOrWhiteSpace(secret.Description) ? "" : $" — {secret.Description}")
                        </option>
                    }
                }
            </optgroup>
        </select>
        
        @if (!string.IsNullOrWhiteSpace(Value) && Value.StartsWith("vault://", StringComparison.OrdinalIgnoreCase))
        {
            <button type="button" 
                    class="btn btn-outline-secondary" 
                    @onclick="ClearReference" 
                    disabled="@Disabled"
                    title="Clear vault reference">
                <i class="bi bi-x-circle"></i>
            </button>
        }
        
        <button type="button" 
                class="btn btn-outline-secondary" 
                @onclick="RefreshSecrets" 
                disabled="@(_loading || Disabled)"
                title="Refresh vault secrets list">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
    
    @if (ShowDirectInput && !string.IsNullOrWhiteSpace(Value) && !Value.StartsWith("vault://", StringComparison.OrdinalIgnoreCase))
    {
        <input type="@(UsePasswordInput ? "password" : "text")" 
               class="form-control mt-2 @InputClass" 
               placeholder="@Placeholder"
               value="@Value"
               @oninput="OnDirectValueChanged"
               disabled="@Disabled" />
    }
    else if (ShowDirectInput && string.IsNullOrWhiteSpace(Value))
    {
        <input type="@(UsePasswordInput ? "password" : "text")" 
               class="form-control mt-2 @InputClass" 
               placeholder="@Placeholder"
               @oninput="OnDirectValueChanged"
               disabled="@Disabled" />
    }
    
    @if (!string.IsNullOrWhiteSpace(HelpText))
    {
        <div class="form-text">@HelpText</div>
    }
    
    @if (!string.IsNullOrWhiteSpace(Value) && Value.StartsWith("vault://", StringComparison.OrdinalIgnoreCase))
    {
        <div class="form-text text-info">
            <i class="bi bi-shield-lock"></i> Using the selected vault reference.
        </div>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; } = "Enter value or select vault reference";
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ShowDirectInput { get; set; } = true;
    [Parameter] public bool UsePasswordInput { get; set; } = true;
    [Parameter] public string ContainerClass { get; set; } = "mb-3";
    [Parameter] public string SelectClass { get; set; } = string.Empty;
    [Parameter] public string InputClass { get; set; } = string.Empty;

    private List<SecretSummaryDto> _secrets = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSecretsAsync();
    }

    private async Task LoadSecretsAsync()
    {
        _loading = true;
        try
        {
            _secrets = (await VaultClient.ListAsync()).ToList();
        }
        catch
        {
            _secrets = new();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshSecrets()
    {
        await LoadSecretsAsync();
        StateHasChanged();
    }

    private async Task OnValueChanged(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString();
        await ValueChanged.InvokeAsync(newValue);
    }

    private async Task OnDirectValueChanged(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString();
        await ValueChanged.InvokeAsync(newValue);
    }

    private async Task ClearReference()
    {
        await ValueChanged.InvokeAsync(null);
    }
}
