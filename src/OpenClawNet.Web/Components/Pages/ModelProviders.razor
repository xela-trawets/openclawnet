@page "/model-providers"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<ModelProviders> Logger
@inject IJSRuntime JS

<PageTitle>OpenClaw .NET - Model Providers</PageTitle>

<h3><i class="bi bi-hdd-rack me-2"></i>Model Providers</h3>

@if (_loading)
{
    <div class="text-muted"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading providers…</div>
}
else
{
<div class="row">
    <div class="col-md-10">

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger py-2 small">@_errorMessage</div>
        }

        @if (_saveSuccess.HasValue)
        {
            <div class="alert @(_saveSuccess.Value ? "alert-success" : "alert-danger") py-2 small">
                @(_saveSuccess.Value ? "✔ Provider saved successfully." : "✘ Failed to save provider.")
            </div>
        }

        @* ── Provider List ─────────────────────────────────── *@
        @if (!_showForm)
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">@_providers.Count provider(s)</span>
                <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm">
                    <i class="bi bi-plus-lg me-1"></i>Add Provider
                </button>
            </div>

            @* ── Bulk-action toolbar ── *@
            @if (_selected.Count > 0)
            {
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="text-muted small">@_selected.Count selected</span>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteSelected" disabled="@_bulkDeleting">
                        @if (_bulkDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Deleting…</span>
                        }
                        else
                        {
                            <span>🗑 Delete @_selected.Count</span>
                        }
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSelection">✕ Deselect all</button>
                </div>
            }
            @if (!string.IsNullOrEmpty(_bulkSkipMessage))
            {
                <div class="alert alert-warning py-1 small">@_bulkSkipMessage</div>
            }

            @if (_providers.Count == 0)
            {
                <div class="alert alert-info">No model providers configured yet. Add one to get started.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:32px;">
                                    <input class="form-check-input" type="checkbox"
                                           checked="@AllSelected"
                                           @onchange="ToggleSelectAll"
                                           title="Select all" />
                                </th>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Last Test</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var provider in _providers)
                            {
                                var isSelected = _selected.Contains(provider.Name);
                                @* ── Main Row ── *@
                                <tr class="@(isSelected ? "table-primary" : "")">
                                    <td>
                                        <input class="form-check-input" type="checkbox"
                                               checked="@isSelected"
                                               @onchange="e => ToggleItem(provider.Name, e)" />
                                    </td>
                                    <td><code>@provider.Name</code></td>
                                    <td>@FormatProviderType(provider.ProviderType)</td>
                                    <td>
                                        @if (provider.IsSupported)
                                        {
                                            <span class="badge bg-success">✅ Enabled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">⏸ Disabled</span>
                                        }
                                    </td>
                                    <td>
                                        @if (_testResults.TryGetValue(provider.Name, out var result))
                                        {
                                            <span class="badge @(result.Success ? "bg-success" : "bg-danger")"
                                                  title="@(result.Success ? "Test succeeded" : result.Message)">
                                                @(result.Success ? "✅ Working" : "❌ Failed")
                                            </span>
                                        }
                                        else if (provider.LastTestedAt.HasValue)
                                        {
                                            var relativeTime = FormatRelativeTime(provider.LastTestedAt.Value);
                                            if (provider.LastTestSucceeded == true)
                                            {
                                                <span title="@provider.LastTestedAt.Value.ToString("u")">
                                                    ✅ @relativeTime
                                                </span>
                                            }
                                            else if (provider.LastTestSucceeded == false)
                                            {
                                                <span class="text-danger" title="@provider.LastTestError">
                                                    ❌ @relativeTime
                                                    @if (!string.IsNullOrEmpty(provider.LastTestError))
                                                    {
                                                        <i class="bi bi-info-circle ms-1" title="@provider.LastTestError"></i>
                                                    }
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-end" style="white-space: nowrap;">
                                        <div class="d-inline-flex flex-nowrap gap-1 justify-content-end">
                                            <button class="btn btn-outline-primary btn-sm" @onclick="() => EditProvider(provider)" title="Edit provider">
                                                <i class="bi bi-pencil"></i> Edit
                                            </button>
                                            <button class="btn @(provider.IsSupported ? "btn-outline-warning" : "btn-outline-success") btn-sm" @onclick="() => ToggleEnabled(provider)" disabled="@_toggling" title="@(provider.IsSupported ? "Disable provider" : "Enable provider")">
                                                @if (provider.IsSupported)
                                                {
                                                    <i class="bi bi-pause-circle"></i> <span>Disable</span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-check-circle"></i> <span>Enable</span>
                                                }
                                            </button>
                                            <button class="btn btn-outline-info btn-sm" @onclick="() => TestProvider(provider.Name)" disabled="@_testing" title="Test connection">
                                                @if (_testing && _testingName == provider.Name)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                }
                                                <i class="bi bi-play-circle"></i> Test
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteProvider(provider.Name)" disabled="@_deleting" title="Delete provider">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                @* ── Sub-Row with provider details ── *@
                                <tr class="@(isSelected ? "table-primary" : "")">
                                    <td></td>
                                    <td colspan="5">
                                        <small class="text-muted">
                                            @* Always-included fields *@
                                            <span>Last tested: </span>
                                            @if (provider.LastTestedAt.HasValue)
                                            {
                                                <span title="@provider.LastTestedAt.Value.ToString("u")">
                                                    @provider.LastTestedAt.Value.ToString("yyyy-MM-dd HH:mm") (@FormatRelativeTime(provider.LastTestedAt.Value))
                                                </span>
                                            }
                                            else
                                            {
                                                <span>Never tested</span>
                                            }
                                            <span> · Test result: </span>
                                            @if (_testResults.TryGetValue(provider.Name, out var testRes))
                                            {
                                                if (testRes.Success)
                                                {
                                                    <span>✅ Success</span>
                                                }
                                                else
                                                {
                                                    <span title="@testRes.Message">❌ Failed</span>
                                                }
                                            }
                                            else if (provider.LastTestSucceeded == true)
                                            {
                                                <span>✅ Success</span>
                                            }
                                            else if (provider.LastTestSucceeded == false)
                                            {
                                                <span title="@provider.LastTestError">❌ Failed</span>
                                            }
                                            else
                                            {
                                                <span>— Never run</span>
                                            }
                                            <span> · Enabled: @(provider.IsSupported ? "Yes" : "No")</span>

                                            @* Type-specific fields *@
                                            @if (provider.ProviderType == "ollama")
                                            {
                                                @if (!string.IsNullOrEmpty(provider.Endpoint))
                                                {
                                                    <span> · Endpoint: <code>@provider.Endpoint</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.Model))
                                                {
                                                    <span> · Model: <code>@provider.Model</code></span>
                                                }
                                            }
                                            else if (provider.ProviderType == "lm-studio")
                                            {
                                                @if (!string.IsNullOrEmpty(provider.Endpoint))
                                                {
                                                    <span> · Endpoint: <code>@provider.Endpoint</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.Model))
                                                {
                                                    <span> · Model: <code>@provider.Model</code></span>
                                                }
                                            }
                                            else if (provider.ProviderType == "azure-openai")
                                            {
                                                @if (!string.IsNullOrEmpty(provider.Endpoint))
                                                {
                                                    <span> · Endpoint: <code>@provider.Endpoint</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.DeploymentName))
                                                {
                                                    <span> · Deployment Name: <code>@provider.DeploymentName</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.AuthMode))
                                                {
                                                    <span> · Auth Mode: @provider.AuthMode</span>
                                                }
                                                <span> · API key: @(provider.HasApiKey ? "Set" : "Not set")</span>
                                            }
                                            else if (provider.ProviderType == "foundry")
                                            {
                                                @if (!string.IsNullOrEmpty(provider.Endpoint))
                                                {
                                                    <span> · Endpoint: <code>@provider.Endpoint</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.Model))
                                                {
                                                    <span> · Model: <code>@provider.Model</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.AuthMode))
                                                {
                                                    <span> · Auth Mode: @provider.AuthMode</span>
                                                }
                                                <span> · API key: @(provider.HasApiKey ? "Set" : "Not set")</span>
                                            }
                                            else if (provider.ProviderType == "foundry-local")
                                            {
                                                @if (!string.IsNullOrEmpty(provider.Model))
                                                {
                                                    <span> · Model: <code>@provider.Model</code></span>
                                                }
                                            }
                                            else if (provider.ProviderType == "github-copilot")
                                            {
                                                @* No extra fields for GitHub Copilot *@
                                            }
                                            else
                                            {
                                                @* Unknown provider type - show all available fields *@
                                                @if (!string.IsNullOrEmpty(provider.Endpoint))
                                                {
                                                    <span> · Endpoint: <code>@provider.Endpoint</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.Model))
                                                {
                                                    <span> · Model: <code>@provider.Model</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.DeploymentName))
                                                {
                                                    <span> · Deployment Name: <code>@provider.DeploymentName</code></span>
                                                }
                                                @if (!string.IsNullOrEmpty(provider.AuthMode))
                                                {
                                                    <span> · Auth Mode: @provider.AuthMode</span>
                                                }
                                                @if (provider.HasApiKey)
                                                {
                                                    <span> · API key: Set</span>
                                                }
                                            }
                                        </small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }

        @* ── Create / Edit Form ───────────────────────────── *@
        @if (_showForm)
        {
            <div class="card">
                <div class="card-header">
                    @(_isEditing ? $"Edit Provider: {_form.Name}" : "Add Provider")
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Name</label>
                        <input type="text" class="form-control" @bind="_form.Name"
                               placeholder="my-provider" disabled="@_isEditing" />
                        <div class="form-text">Unique identifier. Cannot be changed after creation.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Provider Type</label>
                        <select class="form-select" @bind="_form.ProviderType">
                            <option value="ollama">Ollama</option>
                            <option value="azure-openai">Azure OpenAI</option>
                            <option value="github-copilot">GitHub Copilot SDK</option>
                            <option value="foundry">Microsoft Foundry</option>
                            <option value="foundry-local">Foundry Local</option>
                            <option value="lm-studio">LM Studio</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Display Name</label>
                        <input type="text" class="form-control" @bind="_form.DisplayName"
                               placeholder="My Provider" />
                    </div>

                    @* ── Ollama fields ──────────────────────────── *@
                    @if (_form.ProviderType == "ollama")
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Endpoint</label>
                            <input type="url" class="form-control" @bind="_form.Endpoint"
                                   placeholder="http://localhost:11434" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Model</label>
                            <input type="text" class="form-control" @bind="_form.Model"
                                   placeholder="gemma4:e2b" />
                        </div>
                    }

                    @* ── Azure OpenAI fields ────────────────────── *@
                    @if (_form.ProviderType == "azure-openai")
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Endpoint</label>
                            <input type="url" class="form-control" @bind="_form.Endpoint"
                                   placeholder="https://your-resource.openai.azure.com/" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Deployment Name</label>
                            <input type="text" class="form-control" @bind="_form.DeploymentName"
                                   placeholder="gpt-5-mini" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Authentication Mode</label>
                            <select class="form-select" @bind="_form.AuthMode">
                                <option value="api-key">API Key</option>
                                <option value="integrated">Integrated (DefaultAzureCredential)</option>
                            </select>
                        </div>
                        @if (_form.AuthMode == "api-key")
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">API Key</label>
                                <input type="password" class="form-control" @bind="_form.ApiKey"
                                       placeholder="Enter API key" />
                            </div>
                        }
                    }

                    @* ── GitHub Copilot fields ──────────────────── *@
                    @if (_form.ProviderType == "github-copilot")
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">GitHub Token</label>
                            <input type="password" class="form-control" @bind="_form.ApiKey"
                                   placeholder="ghp_... or gho_..." />
                            <div class="form-text">
                                Personal access token or OAuth token with Copilot access.
                                Falls back to <code>GH_TOKEN</code> / <code>GITHUB_TOKEN</code> env vars, then <code>gh auth</code> CLI.
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Model (optional)</label>
                            <input type="text" class="form-control" @bind="_form.Model"
                                   placeholder="Default (Copilot selects)" />
                            <div class="form-text">
                                Leave empty for Copilot's default. Options: <code>gpt-5-mini</code>, <code>gpt-5</code>, <code>claude-sonnet-4.5</code>
                            </div>
                        </div>
                        <div class="alert alert-info py-2 small">
                            <i class="bi bi-info-circle me-1"></i>
                            Auth priority: Token field → <code>COPILOT_GITHUB_TOKEN</code> / <code>GH_TOKEN</code> / <code>GITHUB_TOKEN</code> env vars → <code>gh auth login</code> CLI.
                        </div>
                    }

                    @* ── Microsoft Foundry fields ───────────────── *@
                    @if (_form.ProviderType == "foundry")
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Endpoint</label>
                            <input type="url" class="form-control" @bind="_form.Endpoint"
                                   placeholder="https://my-project.services.ai.azure.com" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Model</label>
                            <input type="text" class="form-control" @bind="_form.Model"
                                   placeholder="gpt-4o-mini" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">API Key</label>
                            <input type="password" class="form-control" @bind="_form.ApiKey"
                                   placeholder="Enter API key" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Auth Mode</label>
                            <select class="form-select" @bind="_form.AuthMode">
                                <option value="api-key">API Key</option>
                                <option value="default-credential">Azure Default Credential</option>
                            </select>
                        </div>
                    }

                    @* ── Foundry Local fields ───────────────────── *@
                    @if (_form.ProviderType == "foundry-local")
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Model</label>
                            <input type="text" class="form-control" @bind="_form.Model"
                                   placeholder="phi-4" />
                            <div class="form-text">Model to load in Foundry Local.</div>
                        </div>
                    }

                    @* ── LM Studio fields ───────────────────────── *@
                    @if (_form.ProviderType == "lm-studio")
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Endpoint</label>
                            <input type="url" class="form-control" @bind="_form.Endpoint"
                                   placeholder="http://localhost:1234" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Model</label>
                            <input type="text" class="form-control" @bind="_form.Model"
                                   placeholder="local-model" />
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="SaveProvider" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            @(_isEditing ? "Update Provider" : "Create Provider")
                        </button>
                        @if (_isEditing)
                        {
                            <button class="btn btn-outline-info" @onclick="() => TestProvider(_form.Name)" disabled="@_testing">
                                @if (_testing && _testingName == _form.Name)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                <i class="bi bi-play-circle me-1"></i>Test Connection
                            </button>
                        }
                        <button class="btn btn-outline-secondary" @onclick="CancelForm">Cancel</button>
                    </div>
                    @if (_isEditing && _testResults.TryGetValue(_form.Name, out var formTestResult))
                    {
                        <div class="mt-2">
                            <span class="badge @(formTestResult.Success ? "bg-success" : "bg-danger")">
                                @(formTestResult.Success ? "✅ Connection successful" : $"❌ Failed — {formTestResult.Message}")
                            </span>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</div>
}

@code {
    // ── State ────────────────────────────────────────────────
    private bool _loading = true;
    private bool _saving;
    private bool _deleting;
    private bool _testing;
    private bool _toggling;
    private bool _bulkDeleting;
    private string? _testingName;
    private bool? _saveSuccess;
    private string _errorMessage = string.Empty;
    private string? _bulkSkipMessage;

    private List<ProviderDto> _providers = new();
    private Dictionary<string, TestResult> _testResults = new();
    private HashSet<string> _selected = new(StringComparer.Ordinal);
    private bool _showForm;
    private bool _isEditing;
    private ProviderFormModel _form = new();

    private bool AllSelected => _providers.Count > 0 && _selected.Count == _providers.Count;

    // ── Lifecycle ────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadProviders();
        _loading = false;
    }

    private async Task LoadProviders()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var result = await http.GetFromJsonAsync<List<ProviderDto>>("/api/model-providers");
            _providers = result ?? new();
            // Prune selection of items that no longer exist
            _selected.RemoveWhere(name => !_providers.Any(p => p.Name == name));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load model providers");
            _errorMessage = "Could not reach the Gateway to load model providers.";
        }
    }

    // ── Form ────────────────────────────────────────────────
    private void ShowCreateForm()
    {
        _form = new ProviderFormModel();
        _isEditing = false;
        _showForm = true;
        _saveSuccess = null;
        _errorMessage = string.Empty;
    }

    private void EditProvider(ProviderDto provider)
    {
        _form = new ProviderFormModel
        {
            Name           = provider.Name,
            ProviderType   = provider.ProviderType ?? "ollama",
            DisplayName    = provider.DisplayName,
            Endpoint       = provider.Endpoint,
            Model          = provider.Model,
            DeploymentName = provider.DeploymentName,
            AuthMode       = provider.AuthMode ?? "api-key",
            ApiKey         = null
        };
        _isEditing = true;
        _showForm = true;
        _saveSuccess = null;
        _errorMessage = string.Empty;
    }

    private void CancelForm()
    {
        _showForm = false;
        _saveSuccess = null;
        _errorMessage = string.Empty;
    }

    private async Task SaveProvider()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _errorMessage = "Provider name is required.";
            return;
        }

        _saving = true;
        _saveSuccess = null;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var request = new
            {
                ProviderType   = _form.ProviderType,
                DisplayName    = NullIfEmpty(_form.DisplayName),
                Endpoint       = NullIfEmpty(_form.Endpoint),
                Model          = NullIfEmpty(_form.Model),
                ApiKey         = NullIfEmpty(_form.ApiKey),
                DeploymentName = NullIfEmpty(_form.DeploymentName),
                AuthMode       = NullIfEmpty(_form.AuthMode)
            };

            var response = await http.PutAsJsonAsync($"/api/model-providers/{_form.Name}", request);
            if (response.IsSuccessStatusCode)
            {
                _saveSuccess = true;
                _showForm = false;
                await LoadProviders();
            }
            else
            {
                _saveSuccess = false;
                _errorMessage = $"Gateway returned {(int)response.StatusCode}.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save model provider");
            _saveSuccess = false;
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
            if (_saveSuccess == true)
            {
                await Task.Delay(4000);
                _saveSuccess = null;
                StateHasChanged();
            }
        }
    }

    // ── Test ────────────────────────────────────────────────
    private async Task TestProvider(string name)
    {
        _testing = true;
        _testingName = name;
        _testResults.Remove(name);
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var response = await http.PostAsync($"/api/model-providers/{name}/test", null);
            var body = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                // Parse the JSON response { success: bool, message: string, lastTestedAt, lastTestSucceeded, lastTestError }
                try
                {
                    var result = System.Text.Json.JsonSerializer.Deserialize<TestApiResponse>(body,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    _testResults[name] = new TestResult(
                        result?.Success ?? false, 
                        result?.Message ?? "No details",
                        result?.LastTestedAt,
                        result?.LastTestSucceeded,
                        result?.LastTestError);
                }
                catch
                {
                    _testResults[name] = new TestResult(true, body, DateTime.UtcNow, true, null);
                }
            }
            else
            {
                _testResults[name] = new TestResult(false, string.IsNullOrWhiteSpace(body)
                    ? $"HTTP {(int)response.StatusCode}"
                    : body, DateTime.UtcNow, false, body);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to test model provider {Name}", name);
            _testResults[name] = new TestResult(false, ex.Message, DateTime.UtcNow, false, ex.Message);
        }
        finally
        {
            _testing = false;
            _testingName = null;
            StateHasChanged();
            await LoadProviders(); // Refresh to get persisted test results
        }
    }

    // ── Toggle Enable/Disable ──────────────────────────────
    private async Task ToggleEnabled(ProviderDto provider)
    {
        _toggling = true;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var request = new
            {
                ProviderType = provider.ProviderType,
                DisplayName = provider.DisplayName,
                Endpoint = provider.Endpoint,
                Model = provider.Model,
                DeploymentName = provider.DeploymentName,
                AuthMode = provider.AuthMode,
                IsSupported = !provider.IsSupported
            };
            await http.PutAsJsonAsync($"/api/model-providers/{provider.Name}", request);
            await LoadProviders();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to toggle provider {Name}", provider.Name);
            _errorMessage = $"Failed to toggle: {ex.Message}";
        }
        finally
        {
            _toggling = false;
            StateHasChanged();
        }
    }

    // ── Delete ──────────────────────────────────────────────
    private async Task DeleteProvider(string name)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", $"Delete model provider '{name}'? This action cannot be undone.");
        if (!confirm) return;

        _deleting = true;
        _saveSuccess = null;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var response = await http.DeleteAsync($"/api/model-providers/{name}");
            if (response.IsSuccessStatusCode)
            {
                _testResults.Remove(name);
                await LoadProviders();
            }
            else
            {
                _errorMessage = $"Failed to delete provider '{name}' — Gateway returned {(int)response.StatusCode}.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete model provider {Name}", name);
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
        finally
        {
            _deleting = false;
            StateHasChanged();
        }
    }

    // ── Bulk selection & delete ─────────────────────────────
    private void ToggleItem(string name, ChangeEventArgs e)
    {
        if (e.Value is true) _selected.Add(name);
        else _selected.Remove(name);
    }

    private void ToggleSelectAll()
    {
        if (AllSelected) _selected.Clear();
        else foreach (var p in _providers) _selected.Add(p.Name);
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _bulkSkipMessage = null;
    }

    private async Task DeleteSelected()
    {
        if (_selected.Count == 0) return;

        var confirm = await JS.InvokeAsync<bool>("confirm", $"Delete {_selected.Count} model provider(s)? This action cannot be undone.");
        if (!confirm) return;

        _bulkDeleting = true;
        _bulkSkipMessage = null;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var names = _selected.ToList();
            var request = new HttpRequestMessage(HttpMethod.Delete, "/api/model-providers")
            {
                Content = JsonContent.Create(new { names })
            };
            var response = await http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _selected.Clear();
                await LoadProviders();
            }
            else
            {
                _errorMessage = $"Bulk delete failed — Gateway returned {(int)response.StatusCode}.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Bulk delete model providers failed");
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
        finally
        {
            _bulkDeleting = false;
            StateHasChanged();
        }
    }

    // ── Helpers ─────────────────────────────────────────────
    private static string? NullIfEmpty(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private static string FormatProviderType(string? type) => type switch
    {
        "ollama"         => "Ollama",
        "azure-openai"   => "Azure OpenAI",
        "github-copilot" => "GitHub Copilot SDK",
        "foundry"        => "Microsoft Foundry",
        "foundry-local"  => "Foundry Local",
        "lm-studio"      => "LM Studio",
        _                => type ?? "Unknown"
    };

    private static string FormatRelativeTime(DateTime utcTime)
    {
        var elapsed = DateTime.UtcNow - utcTime;
        return elapsed.TotalMinutes switch
        {
            < 1 => "just now",
            < 60 => $"{(int)elapsed.TotalMinutes} min ago",
            < 1440 => $"{(int)elapsed.TotalHours} hr ago",
            _ => $"{(int)elapsed.TotalDays} days ago"
        };
    }

    // ── Form Model ──────────────────────────────────────────
    private sealed class ProviderFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string ProviderType { get; set; } = "ollama";
        public string? DisplayName { get; set; }
        public string? Endpoint { get; set; }
        public string? Model { get; set; }
        public string? ApiKey { get; set; }
        public string? DeploymentName { get; set; }
        public string? AuthMode { get; set; } = "api-key";
    }

    // ── DTOs ────────────────────────────────────────────────
    private sealed record ProviderDto(
        string Name, string ProviderType, string? DisplayName, string? Endpoint,
        string? Model, bool HasApiKey, string? DeploymentName, string? AuthMode,
        bool IsSupported, DateTime CreatedAt, DateTime UpdatedAt,
        DateTime? LastTestedAt, bool? LastTestSucceeded, string? LastTestError);

    private sealed record TestResult(bool Success, string? Message, DateTime? LastTestedAt, bool? LastTestSucceeded, string? LastTestError);
    private sealed record TestApiResponse { 
        public bool Success { get; init; } 
        public string? Message { get; init; }
        public DateTime? LastTestedAt { get; init; }
        public bool? LastTestSucceeded { get; init; }
        public string? LastTestError { get; init; }
    }
}
