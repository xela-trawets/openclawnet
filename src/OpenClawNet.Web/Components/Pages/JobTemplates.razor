@page "/jobs/templates"
@rendermode InteractiveServer
@using OpenClawNet.Web.Models.Jobs
@inject OpenClawNet.Web.Services.JobsClient JobsClient
@inject NavigationManager Navigation

<PageTitle>OpenClaw .NET - Job Templates</PageTitle>

<h3>📄 Job Templates</h3>

<p class="text-muted">
    Pre-canned job configurations distilled from the <a href="https://github.com/elbruno/openclawnet-plan/tree/main/docs/demos/tools" target="_blank">demos in <code>docs/demos/tools/</code></a>.
    Pick one, review the prerequisites, and click <strong>Use this template</strong> to create a job seeded with its prompt, schedule, and tool list.
</p>

@if (_loading)
{
    <p>Loading templates…</p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_templates.Count == 0)
{
    <div class="alert alert-warning">No templates returned by the gateway.</div>
}
else
{
    <div class="row g-3">
        @foreach (var t in _templates)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@t.Name</h5>
                            @if (!string.IsNullOrEmpty(t.Category))
                            {
                                <span class="badge bg-secondary">@t.Category</span>
                            }
                        </div>
                        <p class="card-text small text-muted">@t.Description</p>

                        @if (t.RequiredTools.Count > 0)
                        {
                            <div class="small mb-2">
                                <strong>Tools:</strong>
                                @foreach (var tool in t.RequiredTools)
                                {
                                    <span class="badge bg-light text-dark border me-1">@tool</span>
                                }
                            </div>
                        }

                        @if (t.RequiredSecrets.Count > 0)
                        {
                            <div class="small mb-2">
                                <strong>Secrets:</strong>
                                @foreach (var s in t.RequiredSecrets)
                                {
                                    <span class="badge bg-warning text-dark me-1">@s</span>
                                }
                            </div>
                        }

                        @if (t.Prerequisites.Count > 0)
                        {
                            <details class="small mb-2">
                                <summary>Prerequisites (@t.Prerequisites.Count)</summary>
                                <ul class="mb-0 mt-1">
                                    @foreach (var p in t.Prerequisites)
                                    {
                                        <li>@p</li>
                                    }
                                </ul>
                            </details>
                        }

                        @if (!string.IsNullOrEmpty(t.DefaultJob.CronExpression))
                        {
                            <p class="small mb-2"><strong>Schedule:</strong> <code>@t.DefaultJob.CronExpression</code></p>
                        }

                        <details class="small mb-3">
                            <summary>Prompt preview</summary>
                            <pre class="bg-light p-2 rounded mt-1" style="white-space:pre-wrap;font-size:0.85em;">@t.DefaultJob.Prompt</pre>
                        </details>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        @if (!string.IsNullOrEmpty(t.DocsUrl))
                        {
                            <a href="@t.DocsUrl" target="_blank" class="small">📖 Read the demo</a>
                        }
                        else
                        {
                            <span></span>
                        }
                        <button class="btn btn-primary btn-sm" @onclick="() => UseTemplate(t)">
                            Use this template →
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (_lastCreatedJob is not null)
{
    <div class="alert alert-success mt-4">
        Created job <strong>@_lastCreatedJob.Name</strong>
        (id <code>@_lastCreatedJob.Id</code>, status <code>@_lastCreatedJob.Status</code>).
        <a href="/jobs">Open the Jobs page →</a>
    </div>
}
@if (_lastError is not null)
{
    <div class="alert alert-danger mt-4">@_lastError</div>
}

@code {
    private List<JobTemplateDto> _templates = [];
    private bool _loading = true;
    private string? _error;
    private JobDto? _lastCreatedJob;
    private string? _lastError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _templates = (await JobsClient.ListTemplatesAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load templates: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task UseTemplate(JobTemplateDto template)
    {
        _lastError = null;
        _lastCreatedJob = null;
        try
        {
            _lastCreatedJob = await JobsClient.CreateAsync(template.DefaultJob);
        }
        catch (Exception ex)
        {
            _lastError = $"Failed to create job from template '{template.Id}': {ex.Message}";
        }
    }
}
