    // ── Inline rename ──

    private void StartRename(JobInfo job)
    {
        _editingJobId = job.Id;
        _editingJobName = job.Name;
        _renameError = null;
        StateHasChanged();
    }

    private void CancelRename()
    {
        _editingJobId = null;
        _editingJobName = null;
        _renameError = null;
        StateHasChanged();
    }

    private async Task HandleRenameKeyDown(KeyboardEventArgs e, JobInfo job)
    {
        if (e.Key == "Enter")
        {
            await SaveRename(job);
        }
        else if (e.Key == "Escape")
        {
            CancelRename();
        }
    }

    private async Task SaveRename(JobInfo job)
    {
        // Validate non-empty
        if (string.IsNullOrWhiteSpace(_editingJobName))
        {
            _renameError = "Name cannot be empty";
            StateHasChanged();
            return;
        }

        // Validate uniqueness (check against other jobs, excluding the current one)
        var trimmedName = _editingJobName.Trim();
        if (_jobs.Any(j => j.Id != job.Id && string.Equals(j.Name, trimmedName, StringComparison.OrdinalIgnoreCase)))
        {
            _renameError = "Name already in use";
            StateHasChanged();
            return;
        }

        // If name hasn't changed, just cancel
        if (string.Equals(trimmedName, job.Name, StringComparison.Ordinal))
        {
            CancelRename();
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("gateway");

            // Use PATCH for inline rename: it's allowed in any job state (Active,
            // Paused, Draft, …) — unlike PUT which rejects non-Draft/Paused with 409.
            var patch = new { Name = trimmedName };
            var response = await client.PatchAsJsonAsync($"api/jobs/{job.Id}", patch);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Job renamed to '{trimmedName}'", MudBlazor.Severity.Success);

                // Update the in-memory model so the grid reflects the change
                // immediately even if the LoadJobsAsync refresh is delayed.
                var idx = _jobs.FindIndex(j => j.Id == job.Id);
                if (idx >= 0)
                {
                    _jobs[idx] = _jobs[idx] with { Name = trimmedName };
                }

                CancelRename();
                await LoadJobsAsync();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _renameError = $"Failed to rename: {body}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _renameError = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    private static string TruncatePrompt(string? prompt)
    {
        if (string.IsNullOrEmpty(prompt)) return "—";
        return prompt.Length <= 60 ? prompt : $"{prompt[..60]}…";
    }

    private static string GetStatusBadgeClass(string? status) => status?.ToLowerInvariant() switch
    {
        "draft" => "bg-secondary",
        "active" => "bg-success",
        "paused" => "bg-warning",
        "cancelled" => "bg-danger",
        "completed" => "bg-info",
        _ => "bg-light"
    };

    private static Color StatusChipColor(string? status) => status?.ToLowerInvariant() switch
    {
        "draft"     => Color.Secondary,
        "active"    => Color.Success,
        "paused"    => Color.Warning,
        "cancelled" => Color.Error,
        "completed" => Color.Info,
        _           => Color.Default,
    };

