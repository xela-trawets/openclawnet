@page "/jobs"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject MudBlazor.ISnackbar Snackbar

<PageTitle>OpenClaw .NET - Jobs</PageTitle>

<h3>Scheduled Jobs</h3>

<p class="text-muted">
    Manage scheduled prompts and recurring automation tasks. Jobs are created by the agent
    using the <code>schedule</code> tool or through the API.
</p>

@* ── Demo Templates ── *@
<div class="mb-4 p-3 rounded-3" style="background:linear-gradient(135deg,#fff7ed 0%,#fef3c7 50%,#fde68a 100%);border:1px solid #f59e0b;">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <h5 class="mb-0">🎯 Demo Templates</h5>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showDemoTemplates = !_showDemoTemplates">
            @(_showDemoTemplates ? "▲ Collapse" : "▼ Expand")
        </button>
    </div>
    <p class="text-muted small mb-2">Launch pre-configured demo scenarios with one click — no curl required.</p>

    @if (_showDemoTemplates)
    {
        <div class="row g-3">
            @* ── Document Processing Pipeline Card ── *@
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="card-title mb-1">📄 Document Processing Pipeline</h6>
                        <p class="card-text small text-muted mb-2">
                            Scans a folder for documents every 30 seconds, generates summaries, and tracks processing status.
                            Runs for 5 minutes — perfect for a live demo.
                        </p>

                        @* Always allow creating a new instance — multiple jobs may coexist per template. *@
                        <div class="mb-2">
                            <input type="text" class="form-control form-control-sm" @bind="_docPipelineFolderPath" placeholder="C:\src\openclawnet-plan\docs\sampleDocs" />
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-warning btn-sm" @onclick="LaunchDocPipeline" disabled="@_demoLaunching">
                                @if (_demoLaunching)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>➕ Create Demo Job</span>
                                }
                            </button>
                            <span class="small text-muted">30s interval · 5 min duration</span>
                        </div>

                        @if (_demoStatusLoading)
                        {
                            <div class="text-muted small mt-2">
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span> Checking existing instances…
                            </div>
                        }
                        else if (_demoPipelineStatus is not null)
                        {
                            @* Latest existing instance — informational only; create button stays enabled. *@
                            <div class="card border-0 bg-light mt-2">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center mb-1">
                                        <span class="badge @GetStatusBadgeClass(_demoPipelineStatus.JobStatus) me-2">@_demoPipelineStatus.JobStatus</span>
                                        <span class="small text-muted">Latest instance</span>
                                        <a href="/jobs/@_demoPipelineStatus.JobId" class="ms-2 small">Open →</a>
                                    </div>
                                    <table class="table table-sm table-borderless mb-0 small">
                                        <tr><td class="text-muted" style="width:110px">Runs</td><td>@_demoPipelineStatus.CompletedRuns completed · @_demoPipelineStatus.FailedRuns failed · @_demoPipelineStatus.TotalRuns total</td></tr>
                                        <tr><td class="text-muted">Next run</td><td>@(_demoPipelineStatus.NextRunAt?.ToLocalTime().ToString("g") ?? "—")</td></tr>
                                        <tr><td class="text-muted">Ends at</td><td>@(_demoPipelineStatus.EndsAt?.ToLocalTime().ToString("g") ?? "—")</td></tr>
                                        @if (_demoPipelineStatus.LatestRun is not null)
                                        {
                                            <tr><td class="text-muted">Latest run</td><td><span class="badge @GetStatusBadgeClass(_demoPipelineStatus.LatestRun.Status)">@_demoPipelineStatus.LatestRun.Status</span> @(_demoPipelineStatus.LatestRun.CompletedAt?.ToLocalTime().ToString("g") ?? "")</td></tr>
                                        }
                                    </table>
                                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="CheckDocPipelineStatus">
                                        🔄 Refresh
                                    </button>
                                </div>
                            </div>
                        }

                        @if (_demoMessage is not null)
                        {
                            <div class="alert @_demoMessageClass py-2 small mt-2 mb-0">@_demoMessage</div>
                        }
                    </div>
                </div>
            </div>

            @* ── Website Watcher Card ── *@
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="card-title mb-1">🌐 Website Watcher</h6>
                        <p class="card-text small text-muted mb-2">
                            Fetches a URL every 15 minutes, hashes the response, and appends a one-line entry to
                            <code>docs/watch-log.txt</code> when the page changes.
                        </p>

                        @* Always show the URL input + create button — multiple watcher instances allowed. *@
                        <div class="mb-2">
                            <input type="text" class="form-control form-control-sm" @bind="_watcherUrl" placeholder="https://example.com" />
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-warning btn-sm" @onclick="LaunchWebsiteWatcher" disabled="@_watcherLaunching">
                                @if (_watcherLaunching)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>➕ Create Demo Job</span>
                                }
                            </button>
                            <span class="small text-muted">Every 15 min</span>
                        </div>

                        @if (_watcherStatus is not null)
                        {
                            <div class="card border-0 bg-light mt-2">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center mb-1">
                                        <span class="badge @GetStatusBadgeClass(_watcherStatus.JobStatus) me-2">@_watcherStatus.JobStatus</span>
                                        <span class="small text-muted">Latest instance</span>
                                        <a href="/jobs/@_watcherStatus.JobId" class="ms-2 small">Open →</a>
                                    </div>
                                    <table class="table table-sm table-borderless mb-0 small">
                                        <tr><td class="text-muted" style="width:110px">Runs</td><td>@_watcherStatus.CompletedRuns completed · @_watcherStatus.FailedRuns failed · @_watcherStatus.TotalRuns total</td></tr>
                                        <tr><td class="text-muted">Next run</td><td>@(_watcherStatus.NextRunAt?.ToLocalTime().ToString("g") ?? "—")</td></tr>
                                    </table>
                                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="CheckWebsiteWatcherStatus">🔄 Refresh</button>
                                </div>
                            </div>
                        }

                        @if (_watcherMessage is not null)
                        {
                            <div class="alert @_watcherMessageClass py-2 small mt-2 mb-0">@_watcherMessage</div>
                        }
                    </div>
                </div>
            </div>

            @* ── Folder Health Report Card ── *@
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="card-title mb-1">📁 Folder Health Report</h6>
                        <p class="card-text small text-muted mb-2">
                            Runs daily at 09:00 UTC: lists a folder, summarises file count + size + most recent file,
                            and writes a markdown report to <code>docs/folder-health-{date}.md</code>.
                        </p>

                        @* Always show folder input + create button — multiple folder-health jobs allowed. *@
                        <div class="mb-2">
                            <input type="text" class="form-control form-control-sm" @bind="_folderPath" placeholder="C:\src\openclawnet-plan\docs" />
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-warning btn-sm" @onclick="LaunchFolderHealth" disabled="@_folderLaunching">
                                @if (_folderLaunching)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>➕ Create Demo Job</span>
                                }
                            </button>
                            <span class="small text-muted">Daily at 09:00 UTC</span>
                        </div>

                        @if (_folderStatus is not null)
                        {
                            <div class="card border-0 bg-light mt-2">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center mb-1">
                                        <span class="badge @GetStatusBadgeClass(_folderStatus.JobStatus) me-2">@_folderStatus.JobStatus</span>
                                        <span class="small text-muted">Latest instance</span>
                                        <a href="/jobs/@_folderStatus.JobId" class="ms-2 small">Open →</a>
                                    </div>
                                    <table class="table table-sm table-borderless mb-0 small">
                                        <tr><td class="text-muted" style="width:110px">Runs</td><td>@_folderStatus.CompletedRuns completed · @_folderStatus.FailedRuns failed · @_folderStatus.TotalRuns total</td></tr>
                                        <tr><td class="text-muted">Next run</td><td>@(_folderStatus.NextRunAt?.ToLocalTime().ToString("g") ?? "—")</td></tr>
                                    </table>
                                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="CheckFolderHealthStatus">🔄 Refresh</button>
                                </div>
                            </div>
                        }

                        @if (_folderMessage is not null)
                        {
                            <div class="alert @_folderMessageClass py-2 small mt-2 mb-0">@_folderMessage</div>
                        }
                    </div>
                </div>
            </div>

            @* ── URL → Markdown Summary Card ── *@
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="card-title mb-1">🌐➡️📝 URL → Markdown Summary</h6>
                        <p class="card-text small text-muted mb-2">
                            Fetches a URL, converts it to clean Markdown via the
                            <code>markdown_convert</code> tool (powered by
                            <a href="https://github.com/elbruno/ElBruno.MarkItDotNet" target="_blank" rel="noopener">ElBruno.MarkItDotNet</a>),
                            then produces a brief AI summary of the page content. Re-runs every hour.
                        </p>

                        <div class="mb-2">
                            <input type="text" class="form-control form-control-sm" @bind="_markdownUrl" placeholder="https://elbruno.com" />
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-warning btn-sm" @onclick="LaunchMarkdownSummary" disabled="@_markdownLaunching">
                                @if (_markdownLaunching)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>➕ Create Demo Job</span>
                                }
                            </button>
                            <span class="small text-muted">Every 1 hour</span>
                        </div>

                        @if (_markdownStatus is not null)
                        {
                            <div class="card border-0 bg-light mt-2">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center mb-1">
                                        <span class="badge @GetStatusBadgeClass(_markdownStatus.JobStatus) me-2">@_markdownStatus.JobStatus</span>
                                        <span class="small text-muted">Latest instance</span>
                                        <a href="/jobs/@_markdownStatus.JobId" class="ms-2 small">Open →</a>
                                    </div>
                                    <table class="table table-sm table-borderless mb-0 small">
                                        <tr><td class="text-muted" style="width:110px">Runs</td><td>@_markdownStatus.CompletedRuns completed · @_markdownStatus.FailedRuns failed · @_markdownStatus.TotalRuns total</td></tr>
                                        <tr><td class="text-muted">Next run</td><td>@(_markdownStatus.NextRunAt?.ToLocalTime().ToString("g") ?? "—")</td></tr>
                                    </table>
                                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="CheckMarkdownSummaryStatus">🔄 Refresh</button>
                                </div>
                            </div>
                        }

                        @if (_markdownMessage is not null)
                        {
                            <div class="alert @_markdownMessageClass py-2 small mt-2 mb-0">@_markdownMessage</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="mb-3">
    <a href="/jobs/new" class="btn btn-primary btn-sm">+ New Job</a>
</div>

@if (_actionError is not null)
{
    <div class="alert alert-danger alert-dismissible py-2 small">
        ⚠️ @_actionError
        <button type="button" class="btn-close btn-sm" @onclick="() => _actionError = null"></button>
    </div>
}

@if (_loading)
{
    <div class="text-center py-4 text-muted">Loading jobs…</div>
}
else if (_loadError is not null)
{
    <div class="alert alert-danger">
        <strong>Could not load jobs.</strong> Is the Gateway running?<br />
        <small>@_loadError</small>
    </div>
}
else if (_jobs.Count == 0)
{
    <div class="alert alert-info">
        No scheduled jobs yet. Create one above or ask the agent to schedule a reminder.
    </div>
}
else
{
    <MudDataGrid T="JobInfo"
                 Items="_jobs"
                 Dense="_dense"
                 Hover="true"
                 Striped="true"
                 Bordered="false"
                 Filterable="true"
                 SortMode="SortMode.Single"
                 ShowColumnOptions="true"
                 Groupable="false"
                 FixedHeader="true"
                 Height="70vh"
                 Elevation="0">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle2">@_jobs.Count job(s)</MudText>
            <MudSpacer />
            <MudSwitch T="bool" Value="_dense" ValueChanged="v => _dense = v"
                       Color="Color.Primary" Label="@(_dense ? "Compact" : "Comfortable")" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <CellTemplate>
                    @{ var job = context.Item; }
                    @if (_editingJobId == job.Id)
                    {
                        <div class="d-flex align-items-center gap-1">
                            <MudTextField @bind-Value="_editingJobName"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true"
                                          Error="@(!string.IsNullOrWhiteSpace(_renameError))"
                                          HelperText="@_renameError"
                                          OnKeyDown="@(e => HandleRenameKeyDown(e, job))"
                                          Style="width: 250px;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check"
                                           Color="Color.Success"
                                           Size="Size.Small"
                                           OnClick="@(() => SaveRename(job))"
                                           title="Save" />
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           OnClick="CancelRename"
                                           title="Cancel" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2">
                            <a href="/jobs/@job.Id" class="text-decoration-none" data-testid="job-row-@job.Id">
                                <strong>@job.Name</strong>
                            </a>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => StartRename(job))"
                                           title="Rename job" />
                        </div>
                    }
                    <div class="small text-muted">@TruncatePrompt(job.Prompt)</div>
                    <div class="small text-muted font-monospace" title="@job.Id" style="user-select:all">
                        <span style="opacity:0.6">id:</span> @job.Id.ToString()
                    </div>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Status" Title="Status">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@StatusChipColor(context.Item.Status)"
                             Variant="Variant.Filled">@context.Item.Status</MudChip>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Type" SortBy="x => x.IsRecurring ? 0 : 1">
                <CellTemplate>
                    @if (context.Item.IsRecurring)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">🔄 Recurring</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">One-time</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.NextRunAt" Title="Next Run">
                <CellTemplate>
                    <small>@(context.Item.NextRunAt?.ToLocalTime().ToString("g") ?? "—")</small>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.LastRunAt" Title="Last Run">
                <CellTemplate>
                    <small>@(context.Item.LastRunAt?.ToLocalTime().ToString("g") ?? "Never")</small>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                <CellTemplate>
                    @{
                        var job = context.Item;
                        var kind = ClassifyJob(job);
                        var primary = GetPrimaryAction(job, kind);
                    }
                    <div class="d-flex flex-column" style="gap:2px;">
                        <div class="d-flex align-items-center" style="gap:4px;">
                            @if (primary is not null)
                            {
                                @if (primary.IsLink)
                                {
                                    <a href="@primary.Href" class="btn btn-sm @primary.CssClass" title="@primary.Tooltip">@primary.Label</a>
                                }
                                else
                                {
                                    <button class="btn btn-sm @primary.CssClass" @onclick="primary.OnClick" title="@primary.Tooltip">@primary.Label</button>
                                }
                            }
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                     Size="Size.Small"
                                     Dense="true"
                                     AnchorOrigin="Origin.BottomRight"
                                     TransformOrigin="Origin.TopRight">
                                @foreach (var item in GetOverflowActions(job, kind))
                                {
                                    @if (item.IsLink)
                                    {
                                        <MudMenuItem Href="@item.Href">@item.Label</MudMenuItem>
                                    }
                                    else
                                    {
                                        <MudMenuItem OnClick="item.OnClick">@item.Label</MudMenuItem>
                                    }
                                }
                            </MudMenu>
                        </div>
                        <small class="text-muted" style="font-size:0.72rem;line-height:1.1;">@GetConsequenceCaption(job, kind)</small>
                    </div>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="JobInfo" PageSizeOptions="new[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    // ── State ──
    private List<JobInfo> _jobs = [];
    private bool _loading = true;
    private bool _dense = true;
    private string? _loadError;
    private string? _actionError;

    // Inline rename state
    private Guid? _editingJobId;
    private string? _editingJobName;
    private string? _renameError;

    // Demo templates
    private bool _showDemoTemplates = true;
    private bool _demoStatusLoading;
    private bool _demoLaunching;
    private string? _demoMessage;
    private string _demoMessageClass = "alert-info";
    private DocPipelineStatusInfo? _demoPipelineStatus;

    // Website Watcher demo
    private string _watcherUrl = "https://example.com";
    private bool _watcherLaunching;
    private string? _watcherMessage;
    private string _watcherMessageClass = "alert-info";
    private DocPipelineStatusInfo? _watcherStatus;

    // Folder Health demo
    private string _folderPath = @"C:\src\openclawnet-plan\docs";
    private string _docPipelineFolderPath = @"C:\src\openclawnet-plan\docs\sampleDocs";
    private bool _folderLaunching;
    private string? _folderMessage;
    private string _folderMessageClass = "alert-info";
    private DocPipelineStatusInfo? _folderStatus;

    // URL → Markdown Summary demo
    private string _markdownUrl = "https://elbruno.com";
    private bool _markdownLaunching;
    private string? _markdownMessage;
    private string _markdownMessageClass = "alert-info";
    private DocPipelineStatusInfo? _markdownStatus;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadJobsAsync(),
            CheckDocPipelineStatus(),
            CheckWebsiteWatcherStatus(),
            CheckFolderHealthStatus(),
            CheckMarkdownSummaryStatus());
    }

    // ── Load jobs from API ──

    private async Task LoadJobsAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var result = await client.GetFromJsonAsync<List<JobInfo>>("api/jobs");
            _jobs = result ?? [];
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            _jobs = [];
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Lifecycle actions (call Scheduler service directly) ──

    private async Task StartJob(Guid jobId)
    {
        await LifecycleActionAsync(jobId, "start");
    }

    private async Task PauseJob(Guid jobId)
    {
        await LifecycleActionAsync(jobId, "pause");
    }

    private async Task ResumeJob(Guid jobId)
    {
        await LifecycleActionAsync(jobId, "resume");
    }

    private async Task CancelJob(Guid jobId)
    {
        await LifecycleActionAsync(jobId, "cancel");
    }

    // Trigger an immediate one-shot execution of the job, independent of its schedule.
    // Hits the Gateway's POST /api/jobs/{id}/run-now (added alongside this UI change).
    private async Task RunJobNow(Guid jobId, string? jobName)
    {
        _actionError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var response = await client.PostAsync($"api/jobs/{jobId}/run-now", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Triggered run for {jobName ?? "job"}", MudBlazor.Severity.Success);
                await LoadJobsAsync();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _actionError = $"Run-now failed ({(int)response.StatusCode}). {body}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _actionError = $"Could not reach the Gateway. {ex.Message}";
            StateHasChanged();
        }
    }

    // ── Type-aware action verbs ──
    // A job's "kind" determines what the lifecycle verbs actually mean to a user:
    //   Recurring  → schedule-oriented verbs ("Activate schedule", "Pause schedule")
    //   OneTime    → fires once at StartAt ("Schedule", "Hold", "Re-arm")
    //   Manual     → no schedule at all; activation effectively means "run now"
    private enum JobKind { Recurring, OneTime, Manual }

    private static JobKind ClassifyJob(JobInfo job)
    {
        if (job.IsRecurring) return JobKind.Recurring;
        if (job.StartAt is DateTime start && start.ToUniversalTime() > DateTime.UtcNow)
            return JobKind.OneTime;
        return JobKind.Manual;
    }

    private sealed record ActionItem(
        string Label,
        string Tooltip,
        string CssClass,
        EventCallback OnClick,
        bool IsLink = false,
        string? Href = null);

    private ActionItem? GetPrimaryAction(JobInfo job, JobKind kind)
    {
        var status = job.Status?.ToLowerInvariant();
        return (status, kind) switch
        {
            ("draft", JobKind.Recurring) => new ActionItem(
                "▶ Activate schedule", "Begin honoring the recurring schedule", "btn-success",
                EventCallback.Factory.Create(this, () => StartJob(job.Id))),
            ("draft", JobKind.OneTime) => new ActionItem(
                "📅 Schedule", "Arm this job to fire once at its StartAt", "btn-success",
                EventCallback.Factory.Create(this, () => StartJob(job.Id))),
            ("draft", JobKind.Manual) => new ActionItem(
                "▶ Run now", "Run this job immediately", "btn-success",
                EventCallback.Factory.Create(this, () => RunJobNow(job.Id, job.Name))),

            ("active", JobKind.Recurring) => new ActionItem(
                "⏸ Pause schedule", "Stop firing on the schedule (job is preserved)", "btn-warning",
                EventCallback.Factory.Create(this, () => PauseJob(job.Id))),
            ("active", JobKind.OneTime) => new ActionItem(
                "⏸ Hold", "Hold the pending one-time fire", "btn-warning",
                EventCallback.Factory.Create(this, () => PauseJob(job.Id))),
            ("active", JobKind.Manual) => new ActionItem(
                "▶ Run now", "Run this job immediately", "btn-success",
                EventCallback.Factory.Create(this, () => RunJobNow(job.Id, job.Name))),

            ("paused", JobKind.Recurring) => new ActionItem(
                "▶ Resume schedule", "Resume the recurring schedule", "btn-success",
                EventCallback.Factory.Create(this, () => ResumeJob(job.Id))),
            ("paused", JobKind.OneTime) => new ActionItem(
                "▶ Re-arm", "Re-arm the one-time fire", "btn-success",
                EventCallback.Factory.Create(this, () => ResumeJob(job.Id))),
            ("paused", JobKind.Manual) => new ActionItem(
                "▶ Resume", "Resume this job", "btn-success",
                EventCallback.Factory.Create(this, () => ResumeJob(job.Id))),

            ("completed", _) or ("cancelled", _) => new ActionItem(
                "🔁 Run again", "Trigger a fresh run of this job", "btn-outline-success",
                EventCallback.Factory.Create(this, () => RunJobNow(job.Id, job.Name))),

            _ => null,
        };
    }

    private IEnumerable<ActionItem> GetOverflowActions(JobInfo job, JobKind kind)
    {
        var status = job.Status?.ToLowerInvariant();
        var items = new List<ActionItem>();

        // Run-now is always available as a secondary on Active recurring/one-time jobs
        // so users can trigger an out-of-band execution without disturbing the schedule.
        if (status is "active" && kind != JobKind.Manual)
        {
            items.Add(new ActionItem("▶ Run now", "", "", EventCallback.Factory.Create(this, () => RunJobNow(job.Id, job.Name))));
        }

        if (status is "active" or "paused")
        {
            items.Add(new ActionItem("⏹ Cancel", "", "", EventCallback.Factory.Create(this, () => CancelJob(job.Id))));
        }

        if (status is "draft" or "paused")
        {
            items.Add(new ActionItem("✏️ Edit", "", "", default, IsLink: true, Href: $"/jobs/{job.Id}/edit"));
        }

        if (status is "draft" or "completed" or "cancelled")
        {
            items.Add(new ActionItem("📋 Duplicate", "", "", EventCallback.Factory.Create(this, () => DuplicateJob(job))));
        }

        if (status is "draft" or "completed" or "cancelled")
        {
            items.Add(new ActionItem("🗑️ Delete", "", "", EventCallback.Factory.Create(this, () => DeleteJob(job.Id))));
        }

        items.Add(new ActionItem("🔍 Open details", "", "", default, IsLink: true, Href: $"/jobs/{job.Id}"));

        return items;
    }

    private static string GetConsequenceCaption(JobInfo job, JobKind kind)
    {
        var status = job.Status?.ToLowerInvariant();
        return (status, kind) switch
        {
            ("active", JobKind.Recurring) when job.NextRunAt.HasValue => $"Next run {job.NextRunAt.Value.ToLocalTime():g}",
            ("active", JobKind.OneTime)   when job.StartAt.HasValue   => $"Will fire once at {job.StartAt.Value.ToLocalTime():g}",
            ("active", JobKind.Manual)                                => "On-demand — only runs when triggered",
            ("draft",  JobKind.Recurring)                             => "Will follow schedule once activated",
            ("draft",  JobKind.OneTime)   when job.StartAt.HasValue   => $"Will fire once at {job.StartAt.Value.ToLocalTime():g}",
            ("draft",  JobKind.Manual)                                => "Will run immediately on activation",
            ("paused", _)                                             => "Currently held — won't fire",
            ("completed", _)                                          => "Finished — re-run to execute again",
            ("cancelled", _)                                          => "Cancelled — re-run to execute again",
            _                                                         => string.Empty,
        };
    }

    private async Task LifecycleActionAsync(Guid jobId, string action)
    {
        _actionError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("scheduler");
            var response = await client.PostAsync($"api/scheduler/jobs/{jobId}/{action}", null);
            if (response.IsSuccessStatusCode)
            {
                await LoadJobsAsync();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _actionError = $"Action '{action}' failed ({(int)response.StatusCode}). {body}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _actionError = $"Could not reach the Scheduler. {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task DeleteJob(Guid jobId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var response = await client.DeleteAsync($"api/jobs/{jobId}");
            if (response.IsSuccessStatusCode)
                await LoadJobsAsync();
        }
        catch { /* Gateway may not be running */ }
