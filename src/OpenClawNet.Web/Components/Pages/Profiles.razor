@page "/profiles"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using OpenClawNet.Web.Models
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<Profiles> Logger
@inject NavigationManager Navigation

<PageTitle>Agent Profiles - OpenClawNet</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="mb-2">Agent Profiles</h1>
            <p class="text-muted">Explore our collection of specialized AI agents</p>
        </div>
    </div>

    @* Filter Controls *@
    <div class="row mb-4">
        <div class="col-12 col-md-4">
            <label for="providerFilter" class="form-label">Filter by Provider</label>
            <select id="providerFilter" class="form-select" @onchange="OnProviderFilterChanged">
                <option value="">All Providers</option>
                @foreach (var provider in _providers)
                {
                    <option value="@provider">@provider</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-8 d-flex align-items-end justify-content-end">
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/agent-profiles")'>
                <i class="bi bi-gear me-2"></i>Manage Profiles
            </button>
        </div>
    </div>

    @* Loading State *@
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading profiles...</span>
            </div>
            <p class="text-muted mt-3">Loading agent profiles...</p>
        </div>
    }
    @* Error State *@
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@_errorMessage
        </div>
    }
    @* Empty State *@
    else if (_filteredProfiles.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <p class="text-muted mt-3">
                @if (string.IsNullOrEmpty(_selectedProvider))
                {
                    <text>No agent profiles found. Create one to get started.</text>
                }
                else
                {
                    <text>No profiles found for provider "@_selectedProvider".</text>
                }
            </p>
            <button class="btn btn-primary mt-2" @onclick='() => Navigation.NavigateTo("/agent-profiles")'>
                <i class="bi bi-plus-circle me-2"></i>Create Agent Profile
            </button>
        </div>
    }
    @* Profile Grid *@
    else
    {
        <div class="row mb-3">
            <div class="col-12">
                <p class="text-muted">
                    Showing @_filteredProfiles.Count of @_profiles.Count profile@(_profiles.Count != 1 ? "s" : "")
                </p>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var profile in _filteredProfiles)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <ProfileCard Profile="profile" />
                </div>
            }
        </div>
    }
</div>

<style>
    .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }
</style>

@code {
    private List<AgentProfileDto> _profiles = new();
    private List<AgentProfileDto> _filteredProfiles = new();
    private List<string> _providers = new();
    private string _selectedProvider = string.Empty;
    private bool _loading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfiles();
    }

    private async Task LoadProfiles()
    {
        _loading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var response = await http.GetAsync("/api/agent-profiles");

            if (response.IsSuccessStatusCode)
            {
                var profiles = await response.Content.ReadFromJsonAsync<List<AgentProfileDto>>();
                _profiles = profiles?.Where(p => p.IsEnabled).OrderBy(p => p.Name).ToList() ?? new();
                
                // Extract unique providers
                _providers = _profiles
                    .Where(p => !string.IsNullOrEmpty(p.Provider))
                    .Select(p => p.Provider!)
                    .Distinct()
                    .OrderBy(p => p)
                    .ToList();

                ApplyFilter();
            }
            else
            {
                _errorMessage = $"Failed to load profiles (HTTP {(int)response.StatusCode}).";
            }
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "Failed to load agent profiles");
            _errorMessage = "Failed to connect to the Gateway. Please ensure the service is running.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error loading profiles");
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnProviderFilterChanged(ChangeEventArgs e)
    {
        _selectedProvider = e.Value?.ToString() ?? string.Empty;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrEmpty(_selectedProvider))
        {
            _filteredProfiles = _profiles;
        }
        else
        {
            _filteredProfiles = _profiles
                .Where(p => string.Equals(p.Provider, _selectedProvider, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }
}

