@page "/tool-log"
@rendermode InteractiveServer

<PageTitle>OpenClaw .NET - Tool Execution Log</PageTitle>

<h3>Tool Execution Log</h3>

<p class="text-muted">
    Real-time log of tool calls made by the agent during chat conversations.
</p>

@if (_logs.Count == 0)
{
    <div class="alert alert-info">
        No tool executions recorded yet. Chat with the agent and request actions that require tools.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Tool</th>
                    <th>Status</th>
                    <th>Duration</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in _logs.OrderByDescending(l => l.Timestamp))
                {
                    <tr>
                        <td class="small">@log.Timestamp.ToString("HH:mm:ss")</td>
                        <td>
                            <span class="badge bg-info">@log.ToolName</span>
                        </td>
                        <td>
                            @if (log.Success)
                            {
                                <span class="badge bg-success">✓ OK</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">✗ Failed</span>
                            }
                        </td>
                        <td class="small">@log.Duration.TotalMilliseconds.ToString("F0")ms</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => ToggleDetails(log)">
                                @(log.ShowDetails ? "Hide" : "Show")
                            </button>
                        </td>
                    </tr>
                    @if (log.ShowDetails)
                    {
                        <tr>
                            <td colspan="5">
                                <div class="p-2 bg-light rounded">
                                    <strong>Arguments:</strong>
                                    <pre class="small mb-1">@log.Arguments</pre>
                                    <strong>Output:</strong>
                                    <pre class="small mb-0" style="max-height: 200px; overflow-y: auto;">@(log.Success ? log.Output : log.Error)</pre>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private readonly List<ToolLogEntry> _logs = [];
    
    private void ToggleDetails(ToolLogEntry log)
    {
        log.ShowDetails = !log.ShowDetails;
    }
    
    private sealed class ToolLogEntry
    {
        public DateTime Timestamp { get; set; }
        public string ToolName { get; set; } = string.Empty;
        public bool Success { get; set; }
        public TimeSpan Duration { get; set; }
        public string Arguments { get; set; } = string.Empty;
        public string Output { get; set; } = string.Empty;
        public string? Error { get; set; }
        public bool ShowDetails { get; set; }
    }
}
