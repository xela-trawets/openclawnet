@page "/agent-profiles"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<AgentProfiles> Logger
@inject IJSRuntime JS

<PageTitle>OpenClaw .NET - Agent Profiles</PageTitle>

<h3>Agent Profiles</h3>

@if (_loading)
{
    <div class="text-muted"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading profiles…</div>
}
else
{
<div class="row">
    <div class="col-md-10">

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger py-2 small">@_errorMessage</div>
        }

        @if (_saveSuccess.HasValue)
        {
            <div class="alert @(_saveSuccess.Value ? "alert-success" : "alert-danger") py-2 small">
                @(_saveSuccess.Value ? "✔ Profile saved successfully." : "✘ Failed to save profile.")
            </div>
        }

        @* ── Profile List ─────────────────────────────────── *@
        @if (!_showForm)
        {
            @* Suggestion banners — surface missing system roles ───────────── *@
            @if (!_profiles.Any(p => string.Equals(p.Kind, "ToolTester", StringComparison.OrdinalIgnoreCase)))
            {
                <div class="alert alert-info d-flex justify-content-between align-items-center py-2">
                    <div>
                        <strong>No <em>ToolTester</em> agent configured.</strong>
                        A ToolTester agent is used by the Tools page to convert natural-language prompts
                        into tool arguments and verify each tool works. Recommended: a powerful model such as Azure OpenAI.
                    </div>
                    <button class="btn btn-sm btn-primary ms-3" @onclick='() => ShowCreateFormForKind("ToolTester")'>
                        <i class="bi bi-plus-lg me-1"></i> Create ToolTester Agent
                    </button>
                </div>
            }
            @if (!_profiles.Any(p => string.Equals(p.Kind, "System", StringComparison.OrdinalIgnoreCase)))
            {
                <div class="alert alert-info d-flex justify-content-between align-items-center py-2">
                    <div>
                        <strong>No <em>System</em> agent configured.</strong>
                        The System agent runs internal background tasks such as translating job text into cron expressions.
                        It is not selectable in chat.
                    </div>
                    <button class="btn btn-sm btn-primary ms-3" @onclick='() => ShowCreateFormForKind("System")'>
                        <i class="bi bi-plus-lg me-1"></i> Create System Agent
                    </button>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">@_profiles.Count profile(s)</span>
                <div>
                    <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm">
                        <i class="bi bi-plus-lg me-1"></i>Create Profile
                    </button>
                    <button class="btn btn-outline-primary btn-sm ms-2" @onclick="ShowImportForm">
                        <i class="bi bi-file-earmark-arrow-up me-1"></i>Import from Markdown
                    </button>
                </div>
            </div>

            @if (_profiles.Count == 0)
            {
                <div class="alert alert-info">No agent profiles configured yet. Create one to get started.</div>
            }
            else
            {
                @* ── Bulk-action toolbar ── *@
                @if (_selected.Count > 0)
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="text-muted small">@_selected.Count selected</span>
                        <button class="btn btn-outline-success btn-sm"
                                @onclick="SetSelectedAsDefault"
                                disabled="@(_selected.Count != 1 || _settingDefault || SelectedIsAlreadyDefault())"
                                title="@SetDefaultButtonTitle()">
                            @if (_settingDefault)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Setting…</span>
                            }
                            else
                            {
                                <span>⭐ Set as Default</span>
                            }
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="DeleteSelected" disabled="@_bulkDeleting">
                            @if (_bulkDeleting)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Deleting…</span>
                            }
                            else
                            {
                                <span>🗑 Delete @_selected.Count</span>
                            }
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSelection">✕ Deselect all</button>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_bulkSkipMessage))
                {
                    <div class="alert alert-warning py-1 small">@_bulkSkipMessage</div>
                }

                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:32px;">
                                    <input class="form-check-input" type="checkbox"
                                           checked="@AllSelected"
                                           @onchange="ToggleSelectAll"
                                           title="Select all" />
                                </th>
                                <th>Name</th>
                                <th>Display Name</th>
                                <th>Labels</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var profile in _profiles)
                            {
                                var isSelected = _selected.Contains(profile.Name);
                                <tr class="@(isSelected ? "table-primary" : "")">
                                    <td>
                                        <input class="form-check-input" type="checkbox"
                                               checked="@isSelected"
                                               @onchange="e => ToggleItem(profile.Name, e)" />
                                    </td>
                                    <td><code>@profile.Name</code></td>
                                    <td>@profile.DisplayName</td>
                                    <td>
                                        @{
                                            var kind = string.IsNullOrWhiteSpace(profile.Kind) ? "Standard" : profile.Kind;
                                            var (kindCss, kindLabel) = kind.ToLowerInvariant() switch
                                            {
                                                "system"     => ("bg-info text-dark", "System"),
                                                "tooltester" => ("bg-warning text-dark", "ToolTester"),
                                                _            => ("bg-secondary", "Standard"),
                                            };
                                        }
                                        @{
                                            var provider = profile.Provider ?? string.Empty;
                                            var providerCss = provider.ToLowerInvariant() switch
                                            {
                                                "azureopenai"   => "bg-primary",
                                                "openai"        => "bg-dark",
                                                "ollama"        => "bg-success",
                                                "foundry"       => "bg-info text-dark",
                                                "foundrylocal"  => "bg-info text-dark",
                                                "githubcopilot" => "bg-dark",
                                                _               => "bg-secondary",
                                            };
                                            var providerLabel = string.IsNullOrWhiteSpace(provider) ? "—" : provider;
                                        }
                                        <span class="badge @kindCss me-1" title="Profile kind">@kindLabel</span>
                                        <span class="badge @providerCss me-1" title="Provider">@providerLabel</span>
                                        @if (profile.IsDefault)
                                        {
                                            <span class="badge bg-success me-1" title="Default profile used in chat">Default</span>
                                        }
                                        @if (profile.IsEnabled)
                                        {
                                            <span class="badge border border-success text-success" title="Profile is enabled">Enabled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger" title="Profile is disabled">Disabled</span>
                                        }
                                    </td>
                                    <td class="text-end" style="white-space: nowrap;">
                                        <div class="d-inline-flex flex-nowrap gap-1 justify-content-end">
                                            <button class="btn btn-outline-info btn-sm" @onclick="() => TestAgent(profile.Name)" disabled="@_testing" title="Test profile">
                                                @if (_testing && _testingName == profile.Name)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                }
                                                <i class="bi bi-play-circle"></i> Test
                                            </button>
                                            <button class="btn btn-outline-primary btn-sm" @onclick="() => EditProfile(profile)" title="Edit profile">
                                                <i class="bi bi-pencil"></i> Edit
                                            </button>
                                            @if (profile.IsEnabled)
                                            {
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => ToggleEnabled(profile.Name, false)" title="Disable profile">
                                                    <i class="bi bi-pause-circle"></i> Disable
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-success btn-sm" @onclick="() => ToggleEnabled(profile.Name, true)" title="Enable profile">
                                                    <i class="bi bi-check-circle"></i> Enable
                                                </button>
                                            }
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteProfile(profile.Name)" disabled="@_deleting" title="Delete profile">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                @* ── Sub-Row with profile details ── *@
                                <tr class="@(isSelected ? "table-primary" : "")">
                                    <td></td>
                                    <td colspan="4">
                                        <small class="text-muted">
                                            @* Last test datetime + result *@
                                            <span>Last tested: </span>
                                            @if (profile.LastTestedAt.HasValue)
                                            {
                                                <span title="@profile.LastTestedAt.Value.ToString("u")">
                                                    @profile.LastTestedAt.Value.ToString("yyyy-MM-dd HH:mm") (@FormatRelativeTime(profile.LastTestedAt.Value))
                                                </span>
                                            }
                                            else
                                            {
                                                <span>Never tested</span>
                                            }
                                            <span> · Test result: </span>
                                            @if (_testResults.TryGetValue(profile.Name, out var testRes))
                                            {
                                                if (testRes.Success)
                                                {
                                                    <span>✅ @(testRes.Message ?? "Success")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-danger" title="@testRes.Message">❌ @(testRes.Message ?? "Failed")</span>
                                                }
                                            }
                                            else if (profile.LastTestSucceeded == true)
                                            {
                                                <span>✅ Success</span>
                                            }
                                            else if (profile.LastTestSucceeded == false)
                                            {
                                                <span class="text-danger" title="@profile.LastTestError">❌ Failed</span>
                                            }
                                            else
                                            {
                                                <span>— Never run</span>
                                            }
                                            @* Tools *@
                                            @if (profile.EnabledTools is { Length: > 0 })
                                            {
                                                <span> · Tools (@profile.EnabledTools.Length): <code>@string.Join(", ", profile.EnabledTools)</code></span>
                                            }
                                            else
                                            {
                                                <span> · Tools: none</span>
                                            }

                                            @* Generation params *@
                                            @if (profile.Temperature.HasValue)
                                            {
                                                <span> · Temperature: @profile.Temperature.Value.ToString("0.##")</span>
                                            }
                                            @if (profile.MaxTokens.HasValue)
                                            {
                                                <span> · MaxTokens: @profile.MaxTokens.Value</span>
                                            }
                                            <span> · Tool approval: @(profile.RequireToolApproval ? "Required" : "Auto")</span>

                                            @* Instructions preview *@
                                            @if (!string.IsNullOrWhiteSpace(profile.Instructions))
                                            {
                                                var preview = profile.Instructions.Length > 120
                                                    ? profile.Instructions.Substring(0, 120) + "…"
                                                    : profile.Instructions;
                                                <span> · Instructions: <em title="@profile.Instructions">@preview</em></span>
                                            }
                                        </small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }

        @* ── Import Form ─────────────────────────────────── *@
        @if (_showImport)
        {
            <div class="card mt-3">
                <div class="card-header">Import Agent Profile from Markdown</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Paste Markdown content</label>
                        <textarea class="form-control" rows="10" @bind="_importMarkdown"
                                  placeholder="---&#10;name: my-agent&#10;provider: ollama&#10;---&#10;# My Agent&#10;&#10;You are a helpful assistant..."></textarea>
                        <div class="form-text">Supports optional YAML front-matter for provider, model, and tool settings.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="ImportProfile" disabled="@_importing">
                            @if (_importing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Import
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="CancelImport">Cancel</button>
                    </div>
                </div>
            </div>
        }

        @* ── Create / Edit Form ───────────────────────────── *@
        @if (_showForm)
        {
            <div class="card">
                <div class="card-header">
                    @(_isEditing ? $"Edit Profile: {_form.Name}" : "Create Profile")
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Name</label>
                        <input type="text" class="form-control" @bind="_form.Name"
                               placeholder="my-agent" disabled="@_isEditing" />
                        <div class="form-text">Unique identifier. Cannot be changed after creation.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Kind</label>
                        <select class="form-select" @bind="_form.Kind" disabled="@_isEditing">
                            <option value="Standard">Standard — usable in Chat</option>
                            <option value="ToolTester">ToolTester — used by the Tools page Probe button</option>
                            <option value="System">System — internal tasks (e.g. cron text→expression)</option>
                        </select>
                        <div class="form-text">
                            Only <strong>Standard</strong> profiles appear in the Chat picker and may be marked as default.
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Display Name</label>
                        <input type="text" class="form-control" @bind="_form.DisplayName"
                               placeholder="My Agent Profile" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Model Provider</label>
                        <select class="form-select" @bind="_form.Provider">
                            <option value="">(Use default)</option>
                            @foreach (var mp in _modelProviders)
                            {
                                <option value="@mp.Name">@(mp.DisplayName ?? mp.Name) (@mp.ProviderType)</option>
                            }
                        </select>
                        <div class="form-text">Select a configured model provider definition. Manage providers on the <a href="/model-providers">Model Providers</a> page.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Instructions</label>
                        <textarea class="form-control" rows="4" @bind="_form.Instructions"
                                  placeholder="System instructions for this agent profile…"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Enabled Tools</label>
                        @if (_toolGroupsLoading)
                        {
                            <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Loading tools…</div>
                        }
                        else if (_toolGroups.Count == 0)
                        {
                            <div class="alert alert-warning py-2 small mb-0">
                                No tools available. Configure MCP servers on the <a href="/mcp-tools">MCP Tools</a> page.
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <small class="text-muted">
                                    @_form.SelectedTools.Count of @_totalToolCount tools selected.
                                    @if (_form.SelectedTools.Count == 0) { <em>Empty = all enabled.</em> }
                                </small>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary me-1" @onclick="SelectAllTools">Select all</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearAllTools">Clear all</button>
                                </div>
                            </div>
                            <div class="border rounded p-2" style="max-height: 320px; overflow-y: auto;">
                                @foreach (var grp in _toolGroups)
                                {
                                    var serverChecked = grp.Tools.All(t => _form.SelectedTools.Contains(t.Name));
                                    var someChecked   = !serverChecked && grp.Tools.Any(t => _form.SelectedTools.Contains(t.Name));
                                    <div class="mb-2">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input"
                                                   id="@($"server-{grp.ServerId}")"
                                                   checked="@serverChecked"
                                                   indeterminate="@someChecked"
                                                   @onchange="@(e => ToggleServer(grp, (bool)e.Value!))" />
                                            <label class="form-check-label fw-semibold" for="@($"server-{grp.ServerId}")">
                                                @grp.ServerName
                                                @if (grp.IsLegacy) { <span class="badge bg-warning text-dark ms-1">legacy</span> }
                                                <span class="text-muted small">(@grp.Tools.Count tool@(grp.Tools.Count == 1 ? "" : "s"))</span>
                                            </label>
                                        </div>
                                        @foreach (var tool in grp.Tools)
                                        {
                                            <div class="form-check ms-4">
                                                <input type="checkbox" class="form-check-input"
                                                       id="@($"tool-{tool.Name}")"
                                                       checked="@_form.SelectedTools.Contains(tool.Name)"
                                                       @onchange="@(e => ToggleTool(tool.Name, (bool)e.Value!))" />
                                                <label class="form-check-label" for="@($"tool-{tool.Name}")"
                                                       title="@tool.Description">
                                                    <code>@tool.Name</code>
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="form-text">
                                Select the tools this profile is allowed to call. Leave empty to enable all tools.
                            </div>
                        }
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Temperature</label>
                            <input type="number" class="form-control" step="0.1" min="0" max="2"
                                   @bind="_form.Temperature" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Max Tokens</label>
                            <input type="number" class="form-control" min="1" max="128000"
                                   @bind="_form.MaxTokens" />
                        </div>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="isDefault" @bind="_form.IsDefault"
                               disabled="@(!string.Equals(_form.Kind, "Standard", StringComparison.OrdinalIgnoreCase))" />
                        <label class="form-check-label" for="isDefault">
                            Set as default profile
                            @if (!string.Equals(_form.Kind, "Standard", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="text-muted small">(only Standard profiles can be default)</span>
                            }
                        </label>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="isEnabled" @bind="_form.IsEnabled" />
                        <label class="form-check-label" for="isEnabled">Profile is enabled</label>
                        <div class="form-text">Disabled profiles are excluded from default/active selection.</div>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="requireToolApproval"
                               @bind="_form.RequireToolApproval" />
                        <label class="form-check-label" for="requireToolApproval">
                            Require user approval before tools execute (recommended)
                        </label>
                        <div class="form-text">
                            When enabled, the agent will pause and ask before running shell, browser, file, or web-fetch tools.
                            Disable for unattended/cron jobs.
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="SaveProfile" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            @(_isEditing ? "Update Profile" : "Create Profile")
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="CancelForm">Cancel</button>
                        @if (_isEditing)
                        {
                            <button class="btn btn-outline-info" @onclick="() => TestAgent(_form.Name)" disabled="@_testing">
                                @if (_testing && _testingName == _form.Name)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                <i class="bi bi-play-circle me-1"></i>Test Agent
                            </button>
                        }
                    </div>
                    @if (_isEditing && _testResults.TryGetValue(_form.Name, out var formTestResult))
                    {
                        <div class="mt-2">
                            <span class="badge @(formTestResult.Success ? "bg-success" : "bg-danger")">
                                @(formTestResult.Success ? $"✅ {formTestResult.Message}" : $"❌ {formTestResult.Message}")
                            </span>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</div>
}

@code {
    // ── State ────────────────────────────────────────────────
    private bool _loading = true;
    private bool _saving;
    private bool _deleting;
    private bool? _saveSuccess;
    private string _errorMessage = string.Empty;
    private bool _showImport;
    private bool _importing;
    private string _importMarkdown = string.Empty;
    private bool _testing;
    private string? _testingName;
    private Dictionary<string, TestResult> _testResults = new();

    private List<AgentProfileDto> _profiles = new();
    private List<ModelProviderDto> _modelProviders = new();
    private List<McpToolGroupDto> _toolGroups = new();
    private bool _toolGroupsLoading;
    private int _totalToolCount;
    private bool _showForm;
    private bool _isEditing;
    private ProfileFormModel _form = new();

    // ── Bulk selection ──────────────────────────────────────
    private readonly HashSet<string> _selected = new(StringComparer.Ordinal);
    private bool _bulkDeleting;
    private bool _settingDefault;
    private string? _bulkSkipMessage;

    private bool AllSelected => _profiles.Count > 0 && _selected.Count == _profiles.Count;

    // ── Lifecycle ────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadProfiles(), LoadModelProviders(), LoadToolGroups());
        _loading = false;
    }

    private async Task LoadToolGroups()
    {
        _toolGroupsLoading = true;
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var result = await http.GetFromJsonAsync<List<McpToolGroupDto>>("/api/mcp/tools/available");
            _toolGroups = result ?? new();
            _totalToolCount = _toolGroups.Sum(g => g.Tools.Count);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load MCP tool catalog");
            _toolGroups = new();
            _totalToolCount = 0;
        }
        finally
        {
            _toolGroupsLoading = false;
        }
    }

    private async Task LoadProfiles()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var result = await http.GetFromJsonAsync<List<AgentProfileDto>>("/api/agent-profiles");
            _profiles = result ?? new();
            // Prune selection of items that no longer exist
            _selected.RemoveWhere(name => !_profiles.Any(p => p.Name == name));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load agent profiles");
            _errorMessage = "Could not reach the Gateway to load agent profiles.";
        }
    }

    private async Task LoadModelProviders()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var result = await http.GetFromJsonAsync<List<ModelProviderDto>>("/api/model-providers");
            _modelProviders = result ?? new();
        }
        catch { _modelProviders = new(); }
    }

    // ── Form ────────────────────────────────────────────────
    private void ShowCreateForm()
    {
        _form = new ProfileFormModel();
        _isEditing = false;
        _showForm = true;
        _showImport = false;
        _saveSuccess = null;
        _errorMessage = string.Empty;
    }

    private void ShowCreateFormForKind(string kind)
    {
        _form = new ProfileFormModel { Kind = kind };
        if (string.Equals(kind, "ToolTester", StringComparison.OrdinalIgnoreCase))
        {
            _form.Name = "tool-tester";
            _form.DisplayName = "Tool Tester";
            _form.Instructions =
                "You are a tool tester. Given a natural-language request and a tool's parameter schema, " +
                "return ONLY a valid JSON object that matches the schema. No prose, no markdown.";
            // ToolTester runs are explicit user intent — no approval prompt.
            _form.RequireToolApproval = false;
        }
        else if (string.Equals(kind, "System", StringComparison.OrdinalIgnoreCase))
        {
            _form.Name = "system";
            _form.DisplayName = "System Agent";
            _form.Instructions =
                "You are an internal system agent. Convert user input into the requested structured output format precisely. " +
                "Respond with only the requested format — no commentary.";
            _form.RequireToolApproval = false;
        }
        _form.IsDefault = false;
        _isEditing = false;
        _showForm = true;
        _showImport = false;
        _saveSuccess = null;
        _errorMessage = string.Empty;
    }

    private void EditProfile(AgentProfileDto profile)
    {
        _form = new ProfileFormModel
        {
            Name            = profile.Name,
            DisplayName     = profile.DisplayName ?? string.Empty,
            Provider        = profile.Provider ?? "ollama",
            Instructions    = profile.Instructions ?? string.Empty,
            SelectedTools   = profile.EnabledTools is { Length: > 0 }
                                  ? new HashSet<string>(profile.EnabledTools, StringComparer.Ordinal)
                                  : new HashSet<string>(StringComparer.Ordinal),
            Temperature     = profile.Temperature,
            MaxTokens       = profile.MaxTokens,
            IsDefault       = profile.IsDefault,
            IsEnabled       = profile.IsEnabled,
            RequireToolApproval = profile.RequireToolApproval,
            Kind            = profile.Kind
        };
        _isEditing = true;
        _showForm = true;
        _saveSuccess = null;
        _errorMessage = string.Empty;
    }

    // ── Tool picker helpers ─────────────────────────────────
    private void ToggleTool(string storageName, bool selected)
    {
        if (selected) _form.SelectedTools.Add(storageName);
        else _form.SelectedTools.Remove(storageName);
    }

    private void ToggleServer(McpToolGroupDto group, bool selected)
    {
        foreach (var t in group.Tools)
        {
            if (selected) _form.SelectedTools.Add(t.Name);
            else _form.SelectedTools.Remove(t.Name);
        }
    }

    private void SelectAllTools()
    {
        foreach (var g in _toolGroups)
            foreach (var t in g.Tools)
                _form.SelectedTools.Add(t.Name);
    }

    private void ClearAllTools() => _form.SelectedTools.Clear();

    private void CancelForm()
    {
        _showForm = false;
        _saveSuccess = null;
        _errorMessage = string.Empty;
    }

    // ── Import ──────────────────────────────────────────────
    private void ShowImportForm()
    {
        _showImport = true;
        _showForm = false;
        _importMarkdown = string.Empty;
        _saveSuccess = null;
        _errorMessage = string.Empty;
    }

    private void CancelImport()
    {
        _showImport = false;
    }

    private async Task ImportProfile()
    {
        if (string.IsNullOrWhiteSpace(_importMarkdown))
        {
            _errorMessage = "Markdown content is required.";
            return;
        }

        _importing = true;
        _saveSuccess = null;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var request = new { Markdown = _importMarkdown };
            var response = await http.PostAsJsonAsync("/api/agent-profiles/import", request);
            if (response.IsSuccessStatusCode)
            {
                _saveSuccess = true;
                _showImport = false;
                await LoadProfiles();
            }
            else
            {
                _saveSuccess = false;
                _errorMessage = $"Import failed — Gateway returned {(int)response.StatusCode}.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to import agent profile");
            _saveSuccess = false;
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
        finally
        {
            _importing = false;
            StateHasChanged();
            if (_saveSuccess == true)
            {
                await Task.Delay(4000);
                _saveSuccess = null;
                StateHasChanged();
            }
        }
    }

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _errorMessage = "Profile name is required.";
            return;
        }

        _saving = true;
        _saveSuccess = null;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");

            var enabledTools = _form.SelectedTools.Count == 0
                ? Array.Empty<string>()
                : _form.SelectedTools.OrderBy(s => s, StringComparer.Ordinal).ToArray();

            var request = new AgentProfileRequest(
                DisplayName:  NullIfEmpty(_form.DisplayName),
                Provider:     _form.Provider,
                Instructions: NullIfEmpty(_form.Instructions),
                EnabledTools: enabledTools,
                Temperature:  _form.Temperature,
                MaxTokens:    _form.MaxTokens,
                IsDefault:    _form.IsDefault,
                RequireToolApproval: _form.RequireToolApproval,
                IsEnabled:    _form.IsEnabled,
                Kind:         _form.Kind
            );

            var response = await http.PutAsJsonAsync($"/api/agent-profiles/{_form.Name}", request);
            if (response.IsSuccessStatusCode)
            {
                _saveSuccess = true;
                _showForm = false;
                await LoadProfiles();
            }
            else
            {
                _saveSuccess = false;
                _errorMessage = $"Gateway returned {(int)response.StatusCode}.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save agent profile");
            _saveSuccess = false;
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
            if (_saveSuccess == true)
            {
                await Task.Delay(4000);
                _saveSuccess = null;
                StateHasChanged();
            }
        }
    }

    private async Task DeleteProfile(string name)
    {
        _deleting = true;
        _saveSuccess = null;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var response = await http.DeleteAsync($"/api/agent-profiles/{name}");
            if (response.IsSuccessStatusCode)
            {
                await LoadProfiles();
            }
            else
            {
                _errorMessage = $"Failed to delete profile '{name}' — Gateway returned {(int)response.StatusCode}.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete agent profile {Name}", name);
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
        finally
        {
            _deleting = false;
            StateHasChanged();
        }
    }

    private static string? NullIfEmpty(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    // ── Bulk selection & delete ─────────────────────────────
    private void ToggleItem(string name, ChangeEventArgs e)
    {
        if (e.Value is true) _selected.Add(name);
        else _selected.Remove(name);
    }

    private void ToggleSelectAll()
    {
        if (AllSelected) _selected.Clear();
        else foreach (var p in _profiles) _selected.Add(p.Name);
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _bulkSkipMessage = null;
    }

    private async Task DeleteSelected()
    {
        if (_selected.Count == 0) return;

        var confirm = await JS.InvokeAsync<bool>("confirm", $"Delete {_selected.Count} profile(s)?");
        if (!confirm) return;

        _bulkDeleting = true;
        _bulkSkipMessage = null;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var names = _selected.ToList();
            var request = new HttpRequestMessage(HttpMethod.Delete, "/api/agent-profiles")
            {
                Content = JsonContent.Create(new { names })
            };
            var response = await http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<BulkDeleteResponseDto>();
                if (result?.Skipped is { Count: > 0 })
                {
                    var defaultSkips = result.Skipped
                        .Where(s => string.Equals(s.Reason, "default-profile", StringComparison.Ordinal))
                        .Select(s => s.Name)
                        .ToList();
                    if (defaultSkips.Count > 0)
                    {
                        _bulkSkipMessage = string.Join("; ",
                            defaultSkips.Select(n => $"Skipped '{n}' (default profile)"));
                    }
                }
                _selected.Clear();
                await LoadProfiles();
            }
            else
            {
                _errorMessage = $"Bulk delete failed — Gateway returned {(int)response.StatusCode}.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Bulk delete agent profiles failed");
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
        finally
        {
            _bulkDeleting = false;
            StateHasChanged();
        }
    }

    private sealed record BulkDeleteResponseDto(List<string> Deleted, List<SkippedDto> Skipped);
    private sealed record SkippedDto(string Name, string Reason);

    // ── Set Default ─────────────────────────────────────────
    private bool SelectedIsAlreadyDefault()
    {
        if (_selected.Count != 1) return false;
        var name = _selected.First();
        return _profiles.Any(p => p.Name == name && p.IsDefault);
    }

    private string SetDefaultButtonTitle()
    {
        if (_selected.Count == 0) return "Select exactly one profile to set as default";
        if (_selected.Count > 1) return "Select only one profile to set as default";
        var name = _selected.First();
        var profile = _profiles.FirstOrDefault(p => p.Name == name);
        if (profile is null) return "Select a profile";
        if (profile.IsDefault) return "Already the default profile";
        if (!profile.IsEnabled) return "Enable the profile before setting it as default";
        return $"Set '{profile.Name}' as the default profile";
    }

    private async Task SetSelectedAsDefault()
    {
        if (_selected.Count != 1) return;
        var name = _selected.First();
        var profile = _profiles.FirstOrDefault(p => p.Name == name);
        if (profile is null || profile.IsDefault) return;

        _settingDefault = true;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var response = await http.PostAsync($"/api/agent-profiles/{Uri.EscapeDataString(name)}/set-default", null);
            if (response.IsSuccessStatusCode)
            {
                _selected.Clear();
                await LoadProfiles();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _errorMessage = $"Failed to set default: {body}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Set-default failed for profile {Name}", name);
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
        finally
        {
            _settingDefault = false;
            StateHasChanged();
        }
    }

