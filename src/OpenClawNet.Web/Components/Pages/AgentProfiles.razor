    // ── Test ────────────────────────────────────────────────
    private async Task TestAgent(string name)
    {
        _testing = true;
        _testingName = name;
        _testResults.Remove(name);
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var response = await http.PostAsync($"/api/agent-profiles/{name}/test", null);
            var body = await response.Content.ReadAsStringAsync();

            try
            {
                var result = System.Text.Json.JsonSerializer.Deserialize<TestApiResponse>(body,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                _testResults[name] = new TestResult(
                    result?.Success ?? false, 
                    result?.Message ?? "No details",
                    result?.LastTestedAt,
                    result?.LastTestSucceeded,
                    result?.LastTestError);
            }
            catch
            {
                _testResults[name] = new TestResult(response.IsSuccessStatusCode, body, DateTime.UtcNow, response.IsSuccessStatusCode, null);
            }
        }
        catch (Exception ex)
        {
            _testResults[name] = new TestResult(false, ex.Message, DateTime.UtcNow, false, ex.Message);
        }
        finally
        {
            _testing = false;
            _testingName = null;
            StateHasChanged();
            await LoadProfiles(); // Refresh to get persisted test results
        }
    }

    private async Task ToggleEnabled(string name, bool isEnabled)
    {
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var request = new { IsEnabled = isEnabled };
            var response = await http.PatchAsJsonAsync($"/api/agent-profiles/{name}/enabled", request);
            if (response.IsSuccessStatusCode)
            {
                await LoadProfiles();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _errorMessage = $"Failed to toggle profile: {error}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to toggle profile {Name}", name);
            _errorMessage = $"Could not reach the Gateway: {ex.Message}";
        }
    }

    private sealed record TestResult(bool Success, string? Message, DateTime? LastTestedAt, bool? LastTestSucceeded, string? LastTestError);
    private sealed record TestApiResponse { 
        public bool Success { get; init; } 
        public string? Message { get; init; }
        public DateTime? LastTestedAt { get; init; }
        public bool? LastTestSucceeded { get; init; }
        public string? LastTestError { get; init; }
    }

    private static string FormatRelativeTime(DateTime utcTime)
    {
        var elapsed = DateTime.UtcNow - utcTime;
        return elapsed.TotalMinutes switch
        {
            < 1 => "just now",
            < 60 => $"{(int)elapsed.TotalMinutes} min ago",
            < 1440 => $"{(int)elapsed.TotalHours} hr ago",
            _ => $"{(int)elapsed.TotalDays} days ago"
        };
    }
