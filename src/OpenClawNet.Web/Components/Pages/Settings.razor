@page "/settings"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<Settings> Logger

<PageTitle>OpenClaw .NET - Settings</PageTitle>

<h3><i class="bi bi-gear me-2"></i>Settings</h3>

@if (_loading)
{
    <div class="text-muted"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading settings…</div>
}
else
{
<div class="row">
    <div class="col-md-8">

        @* ── Scheduler Settings Card ─────────────────────────── *@
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Scheduler Settings</span>
                @if (_schedulerSaveSuccess.HasValue)
                {
                    <span class="badge @(_schedulerSaveSuccess.Value ? "bg-success" : "bg-danger")">
                        @(_schedulerSaveSuccess.Value ? "✔ Saved" : "✘ Error")
                    </span>
                }
            </div>
            <div class="card-body">
                @if (_schedulerError is not null)
                {
                    <div class="alert alert-warning py-2 small">@_schedulerError</div>
                }
                <div class="mb-3">
                    <label class="form-label fw-semibold">Max Concurrent Jobs</label>
                    <input type="number" class="form-control" min="1" max="20"
                           @bind="_schedulerSettings.MaxConcurrentJobs" />
                    <div class="form-text">How many jobs can run in parallel (1–20).</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Job Timeout (seconds)</label>
                    <input type="number" class="form-control" min="10" max="3600"
                           @bind="_schedulerSettings.JobTimeoutSeconds" />
                    <div class="form-text">Force-cancel a job after this many seconds (10–3600).</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Poll Interval (seconds)</label>
                    <input type="number" class="form-control" min="5" max="3600"
                           @bind="_schedulerSettings.PollIntervalSeconds" />
                    <div class="form-text">How often to check for due jobs (5–3600).</div>
                </div>
                <button class="btn btn-primary" @onclick="SaveSchedulerSettings" disabled="@_schedulerSaving">
                    @if (_schedulerSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Save Scheduler Settings
                </button>
                <a class="btn btn-outline-secondary ms-2" href="/scheduler" target="_blank">
                    <i class="bi bi-box-arrow-up-right me-1"></i>Open Scheduler UI
                </a>
            </div>
        </div>

        @* ── Storage Location Card ───────────────────────────── *@
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Storage Location</span>
                @if (_storageSaveSuccess.HasValue)
                {
                    <span class="badge @(_storageSaveSuccess.Value ? "bg-success" : "bg-danger")">
                        @(_storageSaveSuccess.Value ? "✔ Saved" : "✘ Error")
                    </span>
                }
            </div>
            <div class="card-body">
                @if (_storageError is not null)
                {
                    <div class="alert alert-warning py-2 small">@_storageError</div>
                }
                @if (_storageSaveSuccess == true)
                {
                    <div class="alert alert-warning py-2 small">⚠ Restart required to apply changes</div>
                }
                <div class="mb-3">
                    <label class="form-label fw-semibold">Current Path</label>
                    <input type="text" class="form-control" readonly value="@_storageLocation?.EffectivePath" />
                    <div class="form-text">Currently resolved storage directory.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">New Path</label>
                    <input type="text" class="form-control" @bind="_newStoragePath" />
                    <div class="form-text">Enter an absolute path (e.g., C:\OpenClawNet\Storage). Changes require restart.</div>
                </div>
                <button class="btn btn-primary" @onclick="SaveStorageLocation" disabled="@_storageSaving">
                    @if (_storageSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Save Storage Location
                </button>
            </div>
        </div>

        @* ── System Info Card ────────────────────────────────── *@
        <div class="card">
            <div class="card-header">System Info</div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tr><td>Version</td><td>0.1.0</td></tr>
                    <tr><td>Runtime</td><td>.NET @Environment.Version</td></tr>
                    <tr><td>OS</td><td>@Environment.OSVersion</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>
}

@code {
    // ── State ────────────────────────────────────────────────
    private bool _loading = true;

    // ── Scheduler Settings ────────────────────────────────────
    private SchedulerSettingsDto _schedulerSettings = new();
    private bool _schedulerSaving;
    private bool? _schedulerSaveSuccess;
    private string? _schedulerError;

    // ── Storage Location ──────────────────────────────────────
    private StorageLocationDto? _storageLocation;
    private string _newStoragePath = string.Empty;
    private bool _storageSaving;
    private bool? _storageSaveSuccess;
    private string? _storageError;

    // ── Lifecycle ────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadSchedulerSettings(),
            LoadStorageLocation()
        );
        _loading = false;
    }

    private async Task LoadSchedulerSettings()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("scheduler");
            var result = await http.GetFromJsonAsync<SchedulerSettingsDto>("/api/scheduler/settings");
            if (result is not null) _schedulerSettings = result;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load scheduler settings");
            _schedulerError = "Scheduler service unavailable — showing defaults.";
        }
    }

    private async Task SaveSchedulerSettings()
    {
        _schedulerSaving = true;
        _schedulerSaveSuccess = null;
        StateHasChanged();
        try
        {
            var http = HttpClientFactory.CreateClient("scheduler");
            var response = await http.PutAsJsonAsync("/api/scheduler/settings", _schedulerSettings);
            _schedulerSaveSuccess = response.IsSuccessStatusCode;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save scheduler settings");
            _schedulerSaveSuccess = false;
            _schedulerError = ex.Message;
        }
        finally
        {
            _schedulerSaving = false;
            StateHasChanged();
            if (_schedulerSaveSuccess == true)
            {
                await Task.Delay(4000);
                _schedulerSaveSuccess = null;
                StateHasChanged();
            }
        }
    }

    private async Task LoadStorageLocation()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("scheduler");
            var result = await http.GetFromJsonAsync<StorageLocationDto>("/api/storage/location");
            if (result is not null)
            {
                _storageLocation = result;
                _newStoragePath = result.RootPath;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load storage location");
            _storageError = "Storage service unavailable — showing defaults.";
        }
    }

    private async Task SaveStorageLocation()
    {
        _storageSaving = true;
        _storageSaveSuccess = null;
        _storageError = null;
        StateHasChanged();
        try
        {
            var http = HttpClientFactory.CreateClient("scheduler");
            var request = new { rootPath = _newStoragePath };
            var response = await http.PutAsJsonAsync("/api/storage/location", request);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<StorageUpdateDto>();
                _storageSaveSuccess = true;
                if (result?.NewPath is not null)
                {
                    _newStoragePath = result.NewPath;
                }
            }
            else
            {
                _storageSaveSuccess = false;
                var errorResult = await response.Content.ReadFromJsonAsync<StorageUpdateDto>();
                _storageError = errorResult?.Message ?? $"Failed with status {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save storage location");
            _storageSaveSuccess = false;
            _storageError = ex.Message;
        }
        finally
        {
            _storageSaving = false;
            StateHasChanged();
            if (_storageSaveSuccess == true)
            {
                await Task.Delay(4000);
                _storageSaveSuccess = null;
                StateHasChanged();
            }
        }
    }

    private sealed class SchedulerSettingsDto
    {
        public int MaxConcurrentJobs { get; set; } = 3;
        public int JobTimeoutSeconds { get; set; } = 300;
        public int PollIntervalSeconds { get; set; } = 30;
    }

    private sealed class StorageLocationDto
    {
        public string RootPath { get; set; } = string.Empty;
        public string EffectivePath { get; set; } = string.Empty;
        public string AgentStoragePath { get; set; } = string.Empty;
    }

    private sealed class StorageUpdateDto
    {
        public bool Success { get; set; }
        public string Message { get; set; } = string.Empty;
        public string? NewPath { get; set; }
    }
}

