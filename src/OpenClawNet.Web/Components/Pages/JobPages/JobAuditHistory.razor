@using System.Net.Http.Json
@using OpenClawNet.Web.Models.Audit
@inject IHttpClientFactory HttpClientFactory

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm text-primary" role="status">
            <span class="visually-hidden">Loading audit history...</span>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @_error
    </div>
}
else if (_changes.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <p class="mb-0">No state changes recorded.</p>
    </div>
}
else
{
    <MudDataGrid T="AuditJobStateChangeDto"
                 Items="_changes"
                 Dense="_dense"
                 Hover="true"
                 Striped="true"
                 Bordered="false"
                 Filterable="true"
                 FilterMode="DataGridFilterMode.Simple"
                 SortMode="SortMode.Single"
                 ShowColumnOptions="true"
                 Groupable="false"
                 FixedHeader="true"
                 Height="60vh"
                 Elevation="0">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle2">@_changes.Count state change(s)</MudText>
            <MudSpacer />
            <MudSwitch T="bool" Value="_dense" ValueChanged="v => _dense = v"
                       Color="Color.Primary" Label="@(_dense ? "Compact" : "Comfortable")" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.ChangedAt" Title="Timestamp" InitialDirection="SortDirection.Descending">
                <CellTemplate>
                    @context.Item.ChangedAt.ToLocalTime().ToString("g")
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.FromStatus" Title="From Status">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@GetStatusChipColor(context.Item.FromStatus)"
                             Variant="Variant.Filled">@context.Item.FromStatus.ToUpperInvariant()</MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ToStatus" Title="To Status">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@GetStatusChipColor(context.Item.ToStatus)"
                             Variant="Variant.Filled">@context.Item.ToStatus.ToUpperInvariant()</MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="Changed By">
                <CellTemplate>
                    @(context.Item.ChangedBy ?? "—")
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Reason" Title="Reason" Filterable="true">
                <CellTemplate>
                    @(context.Item.Reason ?? "—")
                </CellTemplate>
            </PropertyColumn>
        </Columns>
    </MudDataGrid>
}

@code {
    [Parameter] public Guid JobId { get; set; }

    private List<AuditJobStateChangeDto> _changes = [];
    private bool _loading = true;
    private string? _error;
    private bool _dense = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAuditHistoryAsync();
    }

    private async Task LoadAuditHistoryAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var response = await client.GetAsync($"api/audit/job-state-changes?jobId={JobId}&limit=500");
            response.EnsureSuccessStatusCode();

            var result = await response.Content.ReadFromJsonAsync<AuditJobStateChangesResponse>();
            _changes = result?.Changes ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Failed to load audit history: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static Color GetStatusChipColor(string? status) => status?.ToLowerInvariant() switch
    {
        "draft" => Color.Secondary,
        "active" => Color.Success,
        "paused" => Color.Warning,
        "cancelled" => Color.Error,
        "completed" => Color.Info,
        _ => Color.Default
    };
}
