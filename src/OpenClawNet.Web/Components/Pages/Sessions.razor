@page "/sessions"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<PageTitle>OpenClaw .NET - Sessions</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Chat Sessions</h3>
    <a class="btn btn-primary btn-sm" href="/">+ New Chat</a>
</div>

<p class="text-muted small">View and manage your conversation history. Sessions are stored in SQLite via the Gateway API.</p>

@if (_loading)
{
    <div class="text-center py-4 text-muted">Loading sessions…</div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">
        <strong>Could not load sessions.</strong> Is the Gateway running?<br />
        <small>@_error</small>
    </div>
}
else if (_sessions.Count == 0)
{
    <div class="text-center text-muted py-5">
        <div style="font-size:2rem;">💬</div>
        <p class="mt-2">No sessions yet. <a href="/">Start chatting</a> to create your first session!</p>
    </div>
}
else
{
    @* ── Filter bar ── *@
    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
        <input type="search" class="form-control form-control-sm" style="max-width:260px"
               placeholder="🔍 Search by title…"
               value="@_searchText"
               @oninput="OnSearchChanged" />
        <select class="form-select form-select-sm" style="max-width:160px"
                value="@_dateFilter"
                @onchange="OnDateFilterChanged">
            <option value="all">All time</option>
            <option value="today">Today</option>
            <option value="7d">Last 7 days</option>
            <option value="30d">Last 30 days</option>
        </select>
        @if (IsFiltered)
        {
            <span class="text-muted small">Showing @_filteredSessions.Count of @_sessions.Count sessions</span>
            <button class="btn btn-link btn-sm p-0" @onclick="ClearFilters">Clear filters</button>
        }
    </div>

    @* ── Bulk-action toolbar ── *@
    <div class="d-flex align-items-center gap-2 mb-2" style="min-height:38px;">
        <div class="form-check mb-0">
            <input class="form-check-input" type="checkbox" id="selectAll"
                   checked="@AllSelected"
                   @onchange="ToggleSelectAll" />
            <label class="form-check-label text-muted small" for="selectAll">
                @if (_selected.Count == 0)
                {
                    <span>Select all</span>
                }
                else
                {
                    <span>@_selected.Count selected</span>
                }
            </label>
        </div>

        @if (_selected.Count > 0)
        {
            <button class="btn btn-danger btn-sm" @onclick="DeleteSelected" disabled="@_bulkDeleting">
                @if (_bulkDeleting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Deleting…</span>
                }
                else
                {
                    <span>🗑 Delete @_selected.Count</span>
                }
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSelection">✕ Deselect all</button>
        }
    </div>

    @* ── Session list ── *@
    @if (_filteredSessions.Count == 0)
    {
        <div class="text-muted small py-3">No sessions match the current filters.</div>
    }
    else
    {
    <div class="list-group">
        @foreach (var (s, index) in _filteredSessions.Select((s, i) => (s, i)))
        {
            var isSelected = _selected.Contains(s.Id);
            <div class="list-group-item d-flex align-items-center gap-2 py-2 @(isSelected ? "list-group-item-primary" : "")"
                 style="cursor:default">

                @* Checkbox *@
                <input class="form-check-input flex-shrink-0" type="checkbox"
                       checked="@isSelected"
                       @onchange="e => ToggleItem(s.Id, e, index)" />

                @if (_renamingId == s.Id)
                {
                    <input class="form-control form-control-sm flex-grow-1" style="max-width:300px"
                           @bind="_renameTitle" @onkeydown="@(e => HandleRenameKey(e, s.Id))" />
                    <button class="btn btn-sm btn-success" @onclick="() => CommitRename(s.Id)">✓</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelRename">✕</button>
                }
                else
                {
                    <a class="flex-grow-1 text-decoration-none text-dark" href="/?sessionId=@s.Id">
                        <span class="fw-semibold">@s.Title</span>
                        <small class="text-muted ms-2">@s.UpdatedAt.ToLocalTime().ToString("MMM d, HH:mm")</small>
                    </a>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartRename(s)" title="Rename">✏️</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSession(s.Id)" title="Delete">🗑</button>
                }
            </div>
        }
    </div>
    }
}

@code {
    private List<SessionDto> _sessions = [];
    private bool _loading = true;
    private string? _error;

    private Guid? _renamingId;
    private string _renameTitle = string.Empty;

    // Bulk selection
    private readonly HashSet<Guid> _selected = [];
    private bool _bulkDeleting;
    private int? _lastClickedIndex; // for shift-click range

    // Filters
    private string _searchText = string.Empty;
    private string _dateFilter = "all"; // all | today | 7d | 30d
    private List<SessionDto> _filteredSessions = [];

    private bool IsFiltered =>
        !string.IsNullOrWhiteSpace(_searchText) || _dateFilter != "all";

    private bool AllSelected => _filteredSessions.Count > 0 && _filteredSessions.All(s => _selected.Contains(s.Id));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _selected.Clear();
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var result = await client.GetFromJsonAsync<List<SessionDto>>("api/sessions");
            _sessions = result ?? [];
            ApplyFilters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Selection logic ──────────────────────────────────────────────

    private void ToggleItem(Guid id, ChangeEventArgs e, int index)
    {
        var check = e.Value is true;

        // Shift+click range-select is not directly available via ChangeEventArgs,
        // so we use the last-clicked index for range when multiple are selected
        if (check)
        {
            _selected.Add(id);
        }
        else
        {
            _selected.Remove(id);
        }

        _lastClickedIndex = index;
    }

    private void ToggleSelectAll()
    {
        if (AllSelected)
            foreach (var s in _filteredSessions) _selected.Remove(s.Id);
        else
            foreach (var s in _filteredSessions) _selected.Add(s.Id);

        _lastClickedIndex = null;
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _lastClickedIndex = null;
    }

    // ── Filters ──────────────────────────────────────────────────────

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private void OnDateFilterChanged(ChangeEventArgs e)
    {
        _dateFilter = e.Value?.ToString() ?? "all";
        ApplyFilters();
    }

    private void ClearFilters()
    {
        _searchText = string.Empty;
        _dateFilter = "all";
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        IEnumerable<SessionDto> q = _sessions;

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var needle = _searchText.Trim();
            q = q.Where(s => s.Title.Contains(needle, StringComparison.OrdinalIgnoreCase));
        }

        var nowUtc = DateTime.UtcNow;
        DateTime? since = _dateFilter switch
        {
            "today" => nowUtc.Date,
            "7d"    => nowUtc.AddDays(-7),
            "30d"   => nowUtc.AddDays(-30),
            _       => null,
        };
        if (since is { } cutoff)
            q = q.Where(s => s.UpdatedAt >= cutoff);

        _filteredSessions = q.ToList();

        // Prune selection of items no longer visible
        var visibleIds = _filteredSessions.Select(s => s.Id).ToHashSet();
        _selected.RemoveWhere(id => !visibleIds.Contains(id));
    }

    // ── Bulk delete ──────────────────────────────────────────────────

    private async Task DeleteSelected()
    {
        if (_selected.Count == 0) return;
        _bulkDeleting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var ids = _selected.ToList();
            var response = await client.SendAsync(new HttpRequestMessage(HttpMethod.Delete, "api/sessions")
            {
                Content = JsonContent.Create(new { ids })
            });
            if (response.IsSuccessStatusCode)
            {
                _sessions.RemoveAll(s => ids.Contains(s.Id));
                _selected.Clear();
                ApplyFilters();
            }
        }
        catch { /* ignore */ }
        finally
        {
            _bulkDeleting = false;
        }
    }

    // ── Individual actions ───────────────────────────────────────────

    private void StartRename(SessionDto s)
    {
        _renamingId = s.Id;
        _renameTitle = s.Title;
    }

    private void CancelRename()
    {
        _renamingId = null;
        _renameTitle = string.Empty;
    }

    private async Task HandleRenameKey(KeyboardEventArgs e, Guid id)
    {
        if (e.Key == "Enter") await CommitRename(id);
        else if (e.Key == "Escape") CancelRename();
    }

    private async Task CommitRename(Guid id)
    {
        if (string.IsNullOrWhiteSpace(_renameTitle)) { CancelRename(); return; }
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            await client.PatchAsJsonAsync($"api/sessions/{id}/title", new { title = _renameTitle });
            var s = _sessions.FirstOrDefault(x => x.Id == id);
            if (s is not null)
                _sessions[_sessions.IndexOf(s)] = s with { Title = _renameTitle };
        }
        catch { /* ignore */ }
        CancelRename();
    }

    private async Task DeleteSession(Guid id)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            await client.DeleteAsync($"api/sessions/{id}");
            _sessions.RemoveAll(s => s.Id == id);
            _selected.Remove(id);
            ApplyFilters();
        }
        catch { /* ignore */ }
    }

    private sealed record SessionDto(Guid Id, string Title, DateTime CreatedAt, DateTime UpdatedAt);
}
