@page "/sessions"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<PageTitle>OpenClaw .NET - Sessions</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Chat Sessions</h3>
    <a class="btn btn-primary btn-sm" href="/chat">+ New Chat</a>
</div>

<p class="text-muted small">View and manage your conversation history. Sessions are stored in SQLite via the Gateway API.</p>

@if (_loading)
{
    <div class="text-center py-4 text-muted">Loading sessions…</div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">
        <strong>Could not load sessions.</strong> Is the Gateway running?<br />
        <small>@_error</small>
    </div>
}
else if (_sessions.Count == 0)
{
    <div class="text-center text-muted py-5">
        <div style="font-size:2rem;">💬</div>
        <p class="mt-2">No sessions yet. <a href="/chat">Start chatting</a> to create your first session!</p>
    </div>
}
else
{
    @* ── Filter bar ── *@
    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
        <input type="search" class="form-control form-control-sm" style="max-width:260px"
               placeholder="🔍 Search by title…"
               value="@_searchText"
               @oninput="OnSearchChanged" />
        <select class="form-select form-select-sm" style="max-width:160px"
                value="@_dateFilter"
                @onchange="OnDateFilterChanged">
            <option value="all">All time</option>
            <option value="today">Today</option>
            <option value="7d">Last 7 days</option>
            <option value="30d">Last 30 days</option>
        </select>
        @if (IsFiltered)
        {
            <span class="text-muted small">Showing @_filteredSessions.Count of @_sessions.Count sessions</span>
            <button class="btn btn-link btn-sm p-0" @onclick="ClearFilters">Clear filters</button>
        }
    </div>

    @* ── Bulk-action toolbar ── *@
    @if (_selected.Count > 0)
    {
        <div class="d-flex align-items-center gap-2 mb-2">
            <span class="text-muted small">@_selected.Count selected</span>
            <button class="btn btn-danger btn-sm" @onclick="ShowBulkDeleteConfirmation" disabled="@_deleteBusy" data-testid="sessions-delete-selected">
                @if (_deleteBusy)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Deleting…</span>
                }
                else
                {
                    <span>🗑 Delete @_selected.Count</span>
                }
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSelection">✕ Deselect all</button>
        </div>
    }

    <MudDataGrid @ref="_grid" T="SessionDto"
                 ServerData="LoadGridDataAsync"
                 Dense="_dense"
                 Hover="true"
                 Striped="true"
                 Bordered="false"
                 Filterable="false"
                 SortMode="SortMode.Single"
                 ShowColumnOptions="true"
                 Groupable="false"
                 FixedHeader="true"
                 Height="70vh"
                 Elevation="0">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle2">@_filteredSessions.Count session(s)</MudText>
            <MudSpacer />
            <MudSwitch T="bool" Value="_dense" ValueChanged="v => _dense = v"
                       Color="Color.Primary" Label="@(_dense ? "Compact" : "Comfortable")" />
        </ToolBarContent>
        <Columns>
            <TemplateColumn Title="" Sortable="false" Filterable="false" CellClass="text-center" HeaderClass="text-center">
                <HeaderTemplate>
                    <input class="form-check-input" type="checkbox"
                           checked="@AllSelected"
                           @onchange="ToggleSelectAll"
                           title="Select all" />
                </HeaderTemplate>
                <CellTemplate>
                    <input class="form-check-input" type="checkbox"
                           checked="@_selected.Contains(context.Item.Id)"
                            @onchange="e => ToggleItem(context.Item.Id, e)"
                            data-testid="session-select-@context.Item.Id" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Title" Title="Title">
                <CellTemplate>
                    @{ var s = context.Item; }
                    @if (_renamingId == s.Id)
                    {
                        <div class="d-inline-flex align-items-center gap-1">
                            <input class="form-control form-control-sm" style="max-width:300px"
                                   @bind="_renameTitle" @onkeydown="@(e => HandleRenameKey(e, s.Id))" />
                            <button class="btn btn-sm btn-success" @onclick="() => CommitRename(s.Id)">✓</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelRename">✕</button>
                        </div>
                    }
                    else
                    {
                        <a class="text-decoration-none text-dark" href="/?sessionId=@s.Id" data-testid="session-row-@s.Id">
                            <span class="fw-semibold">@s.Title</span>
                        </a>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.UpdatedAt" Title="Updated" InitialDirection="SortDirection.Descending">
                <CellTemplate>
                    <small class="text-muted">@context.Item.UpdatedAt.ToLocalTime().ToString("MMM d, HH:mm")</small>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" CellClass="text-end">
                <CellTemplate>
                    @{ var s = context.Item; }
                    @if (_renamingId != s.Id)
                    {
                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => StartRename(s)" title="Rename">✏️</button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => ShowSingleDeleteConfirmation(s.Id)"
                                title="Delete"
                                data-testid="session-delete-@s.Id">🗑</button>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="SessionDto" PageSizeOptions="new[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudDataGrid>

    @if (_showDeleteConfirmation)
    {
        <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="sessionsDeleteTitle" data-testid="session-delete-dialog">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content border-danger">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title" id="sessionsDeleteTitle" data-testid="session-delete-title">
                            <span class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></span>
                            Delete Session@( _pendingDeleteIds.Count == 1 ? string.Empty : "s")
                        </h5>
                        <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="CancelDeleteConfirmation" disabled="@_deleteBusy"></button>
                    </div>
                    <div class="modal-body">
                        @if (_pendingDeleteIds.Count == 1)
                        {
                            var session = _sessions.FirstOrDefault(s => s.Id == _pendingDeleteIds[0]);
                            <p class="mb-0">Are you sure you want to delete <strong>'@(session?.Title ?? "this session")'</strong>? This cannot be undone.</p>
                        }
                        else
                        {
                            <p class="mb-0">Are you sure you want to delete <strong>@_pendingDeleteIds.Count sessions</strong>? This cannot be undone.</p>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CancelDeleteConfirmation" disabled="@_deleteBusy" data-testid="session-delete-cancel">Cancel</button>
                        <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteConfirmation" disabled="@_deleteBusy" data-testid="session-delete-confirm">
                            @if (_deleteBusy)
                            {
                                <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                            }
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }
}

@code {
    private List<SessionDto> _sessions = [];
    private List<SessionDto> _filteredSessions = [];
    private bool _loading = true;
    private string? _error;
    private bool _dense = true;
    private MudDataGrid<SessionDto>? _grid;

    private Guid? _renamingId;
    private string _renameTitle = string.Empty;

    private readonly HashSet<Guid> _selected = [];
    private bool _deleteBusy;
    private bool _showDeleteConfirmation;
    private List<Guid> _pendingDeleteIds = [];

    private string _searchText = string.Empty;
    private string _dateFilter = "all";

    private bool IsFiltered =>
        !string.IsNullOrWhiteSpace(_searchText) || _dateFilter != "all";

    private bool AllSelected => _filteredSessions.Count > 0 && _filteredSessions.All(s => _selected.Contains(s.Id));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _selected.Clear();
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var result = await client.GetFromJsonAsync<List<SessionDto>>("api/sessions");
            _sessions = result ?? [];
            ApplyFilters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── ServerData callback: paging + sorting come from MudDataGrid state ──

    private Task<GridData<SessionDto>> LoadGridDataAsync(GridState<SessionDto> state, CancellationToken ct)
    {
        IEnumerable<SessionDto> q = _filteredSessions;

        // Apply sort definitions from the grid header
        foreach (var sd in state.SortDefinitions)
        {
            q = sd.Descending
                ? q.OrderByDescending(x => sd.SortFunc(x))
                : q.OrderBy(x => sd.SortFunc(x));
        }

        var total = _filteredSessions.Count;
        var page = q.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return Task.FromResult(new GridData<SessionDto>
        {
            Items = page,
            TotalItems = total,
        });
    }

    // ── Selection logic ──

    private void ToggleItem(Guid id, ChangeEventArgs e)
    {
        if (e.Value is true) _selected.Add(id);
        else _selected.Remove(id);
    }

    private void ToggleSelectAll()
    {
        if (AllSelected)
            foreach (var s in _filteredSessions) _selected.Remove(s.Id);
        else
            foreach (var s in _filteredSessions) _selected.Add(s.Id);
    }

    private void ClearSelection() => _selected.Clear();

    private void ShowSingleDeleteConfirmation(Guid id)
    {
        _pendingDeleteIds = [id];
        _showDeleteConfirmation = true;
    }

    private void ShowBulkDeleteConfirmation()
    {
        if (_selected.Count == 0) return;
        _pendingDeleteIds = _selected.ToList();
        _showDeleteConfirmation = true;
    }

    private void CancelDeleteConfirmation()
    {
        if (_deleteBusy) return;
        _showDeleteConfirmation = false;
        _pendingDeleteIds = [];
    }

    // ── Filters ──

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
        if (_grid is not null) await _grid.ReloadServerData();
    }

    private async Task OnDateFilterChanged(ChangeEventArgs e)
    {
        _dateFilter = e.Value?.ToString() ?? "all";
        ApplyFilters();
        if (_grid is not null) await _grid.ReloadServerData();
    }

    private async Task ClearFilters()
    {
        _searchText = string.Empty;
        _dateFilter = "all";
        ApplyFilters();
        if (_grid is not null) await _grid.ReloadServerData();
    }

    private void ApplyFilters()
    {
        IEnumerable<SessionDto> q = _sessions;

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var needle = _searchText.Trim();
            q = q.Where(s => s.Title.Contains(needle, StringComparison.OrdinalIgnoreCase));
        }

        var nowUtc = DateTime.UtcNow;
        DateTime? since = _dateFilter switch
        {
            "today" => nowUtc.Date,
            "7d"    => nowUtc.AddDays(-7),
            "30d"   => nowUtc.AddDays(-30),
            _       => null,
        };
        if (since is { } cutoff)
            q = q.Where(s => s.UpdatedAt >= cutoff);

        _filteredSessions = q.ToList();

        var visibleIds = _filteredSessions.Select(s => s.Id).ToHashSet();
        _selected.RemoveWhere(id => !visibleIds.Contains(id));
    }

    // ── Bulk delete ──

    private async Task ConfirmDeleteConfirmation()
    {
        if (_pendingDeleteIds.Count == 0) return;
        _deleteBusy = true;
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var ids = _pendingDeleteIds.ToList();
            HttpResponseMessage response;
            if (ids.Count == 1)
            {
                response = await client.DeleteAsync($"api/sessions/{ids[0]}");
            }
            else
            {
                response = await client.SendAsync(new HttpRequestMessage(HttpMethod.Delete, "api/sessions")
                {
                    Content = JsonContent.Create(new { ids })
                });
            }

            if (response.IsSuccessStatusCode)
            {
                _sessions.RemoveAll(s => ids.Contains(s.Id));
                _selected.RemoveWhere(id => ids.Contains(id));
                ApplyFilters();
                if (_grid is not null) await _grid.ReloadServerData();
                _showDeleteConfirmation = false;
                _pendingDeleteIds = [];
            }
        }
        catch { /* ignore */ }
        finally
        {
            _deleteBusy = false;
        }
    }

    // ── Individual actions ──

    private void StartRename(SessionDto s)
    {
        _renamingId = s.Id;
        _renameTitle = s.Title;
    }

    private void CancelRename()
    {
        _renamingId = null;
        _renameTitle = string.Empty;
    }

    private async Task HandleRenameKey(KeyboardEventArgs e, Guid id)
    {
        if (e.Key == "Enter") await CommitRename(id);
        else if (e.Key == "Escape") CancelRename();
    }

    private async Task CommitRename(Guid id)
    {
        if (string.IsNullOrWhiteSpace(_renameTitle)) { CancelRename(); return; }
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            await client.PatchAsJsonAsync($"api/sessions/{id}/title", new { title = _renameTitle });
            var s = _sessions.FirstOrDefault(x => x.Id == id);
            if (s is not null)
                _sessions[_sessions.IndexOf(s)] = s with { Title = _renameTitle };
            ApplyFilters();
            if (_grid is not null) await _grid.ReloadServerData();
        }
        catch { /* ignore */ }
        CancelRename();
    }

    private sealed record SessionDto(Guid Id, string Title, DateTime CreatedAt, DateTime UpdatedAt);
}
