@page "/skills"
@rendermode InteractiveServer
@inject IConfiguration Configuration
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@using System.IO
@using System.IO.Compression
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>OpenClaw .NET - Skills</PageTitle>

<h3>Skills</h3>

<p class="text-muted">
    Skills are markdown-based instructions that customize the agent's behavior.
    You can enable/disable built-in skills or install skills from the community marketplace.
</p>

@* Tabs *@
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_tab == "installed" ? "active" : "")" @onclick='() => SetTab("installed")'>
            📦 Installed <span class="badge bg-secondary ms-1">@_skills.Count</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_tab == "marketplace" ? "active" : "")" @onclick='() => LoadMarketplace()'>
            🛒 Marketplace
            @if (_marketplaceLoading) { <span class="spinner-border spinner-border-sm ms-1"></span> }
        </button>
    </li>
</ul>

@if (_tab == "installed")
{
    <div class="mb-3 d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" @onclick="ReloadSkills" disabled="@_loading">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-1"></span> } 🔄 Reload
        </button>
        <button class="btn btn-primary btn-sm" @onclick="OnImportClick" disabled="@_importing">
            @if (_importing) { <span class="spinner-border spinner-border-sm me-1"></span> } ⬇️ Import Skill
        </button>
        <InputFile @ref="_fileInput" OnChange="OnFileSelected" style="display:none;" accept=".md,.zip" />
    </div>

    @* Toast notifications *@
    @if (!string.IsNullOrEmpty(_toastMessage))
    {
        <div class="alert alert-@(_toastIsError ? "danger" : "success") alert-dismissible fade show mb-3" role="alert">
            @_toastMessage
            <button type="button" class="btn-close" @onclick="ClearToast"></button>
        </div>
    }

    @if (_loading)
    {
        <div class="text-muted">Loading skills…</div>
    }
    else if (_skills.Count == 0)
    {
        <div class="alert alert-info">
            No skills installed yet. Visit the <button class="btn btn-link p-0 align-baseline" @onclick="LoadMarketplace">Marketplace</button> to install community skills.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var skill in _skills)
            {
                <div class="col-md-6">
                    <div class="card h-100 @(!skill.Enabled ? "border-secondary opacity-75" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">@skill.Name</h5>
                                <div class="d-flex gap-1 align-items-center">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" checked="@skill.Enabled"
                                               @onchange="() => ToggleSkill(skill)" />
                                    </div>
                                    @if (skill.Source == "installed")
                                    {
                                        <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Uninstall"
                                                @onclick="() => UninstallSkill(skill.Name)">🗑</button>
                                    }
                                </div>
                            </div>
                            <p class="card-text small">@skill.Description</p>
                            @if (!string.IsNullOrEmpty(skill.Category))
                            {
                                <span class="badge bg-secondary me-1">@skill.Category</span>
                            }
                            @foreach (var tag in skill.Tags)
                            {
                                <span class="badge bg-info me-1">@tag</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else if (_tab == "marketplace")
{
    @if (_marketplaceError is not null)
    {
        <div class="alert alert-danger">@_marketplaceError</div>
    }

    @if (_marketplaceLoading)
    {
        <div class="text-muted">Fetching community skills from GitHub…</div>
    }
    else if (_marketplaceSkills.Count == 0 && _marketplaceError is null)
    {
        <div class="text-muted">No marketplace skills found.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var ms in _marketplaceSkills)
            {
                var isInstalled = _skills.Any(s => s.Name.Equals(ms.Name, StringComparison.OrdinalIgnoreCase));
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">@ms.Name</h5>
                                @if (isInstalled)
                                {
                                    <span class="badge bg-success">✓ Installed</span>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="() => InstallMarketplaceSkill(ms)"
                                            disabled="@_installing.Contains(ms.Name)">
                                        @if (_installing.Contains(ms.Name))
                                        { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        Install
                                    </button>
                                }
                            </div>
                            <p class="card-text small text-muted">
                                <a href="@ms.GitHubUrl" target="_blank" rel="noopener">View on GitHub ↗</a>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private string _tab = "installed";
    private List<SkillRow> _skills = [];
    private List<MarketplaceItem> _marketplaceSkills = [];
    private HashSet<string> _installing = new(StringComparer.OrdinalIgnoreCase);
    private bool _loading;
    private bool _marketplaceLoading;
    private bool _importing;
    private string? _marketplaceError;
    private string _gatewayUrl = string.Empty;
    private string? _toastMessage;
    private bool _toastIsError;
    private InputFile? _fileInput;

    protected override async Task OnInitializedAsync()
    {
        _gatewayUrl = Configuration["GatewayUrl"] ?? "https://localhost:7295";
        await LoadSkillsAsync();
    }

    private async Task LoadSkillsAsync()
    {
        _loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var defs = await client.GetFromJsonAsync<SkillDefinitionDto[]>("api/skills") ?? [];
            _skills = defs.Select(d => new SkillRow(d.Name, d.Description ?? "", d.Category, d.Enabled, d.Tags ?? [], d.Source ?? "built-in")).ToList();
        }
        catch { /* gateway may be offline */ }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadSkills()
    {
        _loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            await client.PostAsync("api/skills/reload", null);
        }
        catch { }
        await LoadSkillsAsync();
    }

    private async Task ToggleSkill(SkillRow skill)
    {
        var client = HttpClientFactory.CreateClient("gateway");
        var endpoint = skill.Enabled ? $"api/skills/{skill.Name}/disable" : $"api/skills/{skill.Name}/enable";
        await client.PostAsync(endpoint, null);
        await LoadSkillsAsync();
    }

    private async Task UninstallSkill(string name)
    {
        var client = HttpClientFactory.CreateClient("gateway");
        await client.DeleteAsync($"api/skills/installed/{Uri.EscapeDataString(name)}");
        await LoadSkillsAsync();
    }

    private void SetTab(string tab) => _tab = tab;

    private async Task LoadMarketplace()
    {
        _tab = "marketplace";
        if (_marketplaceSkills.Count > 0) return; // already loaded

        _marketplaceLoading = true;
        _marketplaceError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var items = await client.GetFromJsonAsync<MarketplaceItemDto[]>("api/skills/marketplace") ?? [];
            _marketplaceSkills = items.Select(i => new MarketplaceItem(i.Name, i.ContentUrl, i.GitHubUrl)).ToList();
        }
        catch (Exception ex)
        {
            _marketplaceError = $"Could not load marketplace: {ex.Message}";
        }
        finally
        {
            _marketplaceLoading = false;
        }
    }

    private async Task InstallMarketplaceSkill(MarketplaceItem ms)
    {
        _installing.Add(ms.Name);
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            await client.PostAsJsonAsync("api/skills/install", new { name = ms.Name, contentUrl = ms.ContentUrl });
            await LoadSkillsAsync();
        }
        catch { }
        finally
        {
            _installing.Remove(ms.Name);
        }
    }

    private sealed record SkillRow(string Name, string Description, string? Category, bool Enabled, string[] Tags, string Source);
    private sealed record MarketplaceItem(string Name, string ContentUrl, string GitHubUrl);

    // DTOs matching Gateway JSON
    private sealed record SkillDefinitionDto(string Name, string? Description, string? Category, bool Enabled, string[]? Tags, string? Source);
    private sealed record MarketplaceItemDto(string Name, string ContentUrl, string GitHubUrl);
    private sealed record ImportResponse(bool Success, string SkillName, string Message);
    private sealed record ErrorResponse(bool Success, string Error);

    private void ClearToast()
    {
        _toastMessage = null;
        _toastIsError = false;
    }

    private void ShowToast(string message, bool isError = false)
    {
        _toastMessage = message;
        _toastIsError = isError;
        StateHasChanged();
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            ClearToast();
            StateHasChanged();
        });
    }

    private async Task OnImportClick()
    {
        if (_fileInput is null) return;
        
        try
        {
            // Use the InputFileInterop helper if available
            // For now, we'll trigger via a workaround using the element reference
            await JS.InvokeVoidAsync("document.querySelector", "input[accept='.md,.zip']").ConfigureAwait(false);
        }
        catch
        {
            // Fallback: just trigger the input via a simple approach
        }
        finally
        {
            // Note: The Blazor InputFile component doesn't expose a click method
            // So we'll use JavaScript to trigger the native input element
            try
            {
                await JS.InvokeVoidAsync("eval", 
                    "document.querySelector('input[accept=\".md,.zip\"]').click()");
            }
            catch (Exception ex)
            {
                ShowToast($"❌ Error opening file picker: {ex.Message}", isError: true);
            }
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _importing = true;
        try
        {
            var file = e.File;
            if (file == null) return;

            // Validate file type
            if (!file.Name.EndsWith(".md", StringComparison.OrdinalIgnoreCase) && 
                !file.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
            {
                ShowToast("❌ Please select a .md or .zip file", isError: true);
                return;
            }

            // Read file into memory
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024); // 5MB max
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            ShowToast("⏳ Importing skill...");

            // Create multipart form data
            var content = new MultipartFormDataContent();
            content.Add(new StreamContent(memoryStream), "file", file.Name);

            // Upload to API
            var client = HttpClientFactory.CreateClient("gateway");
            var response = await client.PostAsync("api/skills/import", content);

            if (response.IsSuccessStatusCode)
            {
                var jsonContent = await response.Content.ReadAsStringAsync();
                var result = JsonSerializer.Deserialize<ImportResponse>(jsonContent, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                await LoadSkillsAsync();
                ShowToast($"✅ Skill imported: {result?.SkillName ?? "Unknown"}");
            }
            else
            {
                var jsonContent = await response.Content.ReadAsStringAsync();
                var errorResult = JsonSerializer.Deserialize<ErrorResponse>(jsonContent, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                ShowToast($"❌ Import failed: {errorResult?.Error ?? "Unknown error"}", isError: true);
            }
        }
        catch (HttpRequestException ex)
        {
            ShowToast($"❌ Import failed: {ex.Message}", isError: true);
        }
        catch (Exception ex)
        {
            ShowToast($"❌ Error: {ex.Message}", isError: true);
        }
        finally
        {
            _importing = false;
        }
    }
}
