@page "/skills"
@rendermode InteractiveServer
@using OpenClawNet.Web.Components.Skills
@using OpenClawNet.Web.Models.Skills
@using OpenClawNet.Web.Services
@inject SkillsClient SkillsClient
@inject JobsClient JobsClient
@inject IJSRuntime JS

<PageTitle>OpenClaw .NET - Skills</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-1">
            <span class="bi bi-book me-2" aria-hidden="true"></span>Skills
        </h3>
        <p class="text-muted mb-0">
            Markdown-based instructions injected into the agent system prompt.
            Layered: agent overrides &gt; installed &gt; system.
        </p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" type="button"
                data-testid="skills-import-button"
                @onclick="ShowImport" disabled="@_loading">
            <span class="bi bi-cloud-download me-1" aria-hidden="true"></span>Import…
        </button>
        <button class="btn btn-primary" @onclick="ShowCreate" disabled="@_loading">
            <span class="bi bi-plus-lg me-1" aria-hidden="true"></span>New skill
        </button>
    </div>
</div>

@if (_pageError is not null)
{
    <div class="alert alert-danger" role="alert">
        <strong>Couldn't load skills:</strong> @_pageError
        <button class="btn btn-link p-0 ms-2 align-baseline" @onclick="LoadAsync">Retry</button>
    </div>
}

<SkillsSnapshotBanner PinnedSnapshotId="@_pinnedSnapshotId" OnRefresh="LoadAsync" />

<ul class="nav nav-tabs mb-3">
    @foreach (var tab in _tabs)
    {
        <li class="nav-item">
            <button class="nav-link @(tab.Key == _activeTab ? "active" : "")"
                    type="button"
                    @onclick="() => SelectTab(tab.Key)">
                @tab.Label <span class="badge bg-secondary ms-1">@CountFor(tab.Key)</span>
            </button>
        </li>
    }
</ul>

<div class="row g-2 mb-3">
    <div class="col-md-5">
        <div class="input-group">
            <span class="input-group-text"><span class="bi bi-search" aria-hidden="true"></span></span>
            <input type="text" class="form-control" placeholder="Search name, description, source…"
                   data-testid="skills-search"
                   @bind="_search" @bind:event="oninput" @bind:after="ApplyFilter" />
        </div>
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="_sourceFilter" @bind:after="ApplyFilter" data-testid="skills-source-filter">
            <option value="">All sources</option>
            @foreach (var src in _allSources)
            {
                <option value="@src">@src</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="_enabledFilter" @bind:after="ApplyFilter" data-testid="skills-enabled-filter">
            <option value="any">Any state</option>
            <option value="enabled">Enabled (any agent)</option>
            <option value="disabled">Disabled everywhere</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="_selectedAgent" @bind:after="ApplyFilter" data-testid="skills-agent-picker">
            <option value="">No agent picked</option>
            @foreach (var agent in _agentNames)
            {
                <option value="@agent">@agent</option>
            }
        </select>
    </div>
</div>

@if (_loading)
{
    <div class="text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Loading skills…</div>
}
else if (_filtered.Count == 0 && _pageError is null)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <div class="display-6 mb-3"><span class="bi bi-book text-muted"></span></div>
            <h5 class="mb-2">No skills match the current filters.</h5>
            <p class="text-muted mb-3">Try a different layer tab, clear the search, or create a new skill.</p>
            <button class="btn btn-primary" @onclick="ShowCreate">
                <span class="bi bi-plus-lg me-1" aria-hidden="true"></span>New skill
            </button>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Description</th>
                    <th scope="col">Layer</th>
                    <th scope="col">Agents</th>
                    <th scope="col">Enabled</th>
                    <th scope="col">Updated</th>
                    <th scope="col" class="text-end" style="width: 1%; white-space: nowrap;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var skill in _filtered)
                {
                    <SkillCard Skill="skill"
                               AgentNames="_agentNames"
                               SelectedAgent="@_selectedAgent"
                               OnView="OpenDrawer"
                               OnDelete="DeleteAsync"
                               OnEnabledChanged="OnEnabledChangedAsync" />
                }
            </tbody>
        </table>
    </div>
}

<SkillAuthoringDialog Visible="_showCreate"
                      OnCancel="HideCreate"
                      OnCreated="OnCreatedAsync" />

<SkillDetailDrawer Visible="_showDrawer"
                   SkillName="@_drawerSkillName"
                   Agents="_agentNames"
                   OnClose="HideDrawer" />

@* Skills import modal *@
@if (_showImport)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="importSkillsTitle">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="importSkillsTitle">
                        <span class="bi bi-cloud-download me-2" aria-hidden="true"></span>Import Skills
                    </h5>
                    <button type="button" class="btn-close" aria-label="Close"
                            @onclick="HideImport"></button>
                </div>
                <div class="modal-body">
                    <SkillsImportFileHandler OnImportSuccess="OnImportSuccessAsync"
                                            OnImportError="OnImportErrorAsync" />
                    <SkillsImportErrorDisplay Error="_importError"
                                             OnDismiss="() => _importError = null"
                                             OnRetry="() => _importError = null" />
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private record TabDef(string Key, string Label);
    private static readonly TabDef[] _tabs =
    {
        new("system",    "System"),
        new("installed", "Installed"),
        new("agent",     "Agent-specific"),
    };

    private List<SkillDto> _skills = new();
    private List<SkillDto> _filtered = new();
    private List<string> _agentNames = new();
    private List<string> _allSources = new();

    private string _activeTab = "installed";
    private string _search = string.Empty;
    private string _sourceFilter = string.Empty;
    private string _enabledFilter = "any";
    private string _selectedAgent = string.Empty;

    private bool _loading;
    private string? _pageError;
    private string? _pinnedSnapshotId;

    // Modal + drawer state
    private bool _showCreate;
    private bool _showDrawer;
    private string? _drawerSkillName;
    private bool _showImport;
    private (string Reason, string? Detail, int StatusCode)? _importError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _pageError = null;
        try
        {
            // Pin snapshot before listing so the banner can detect divergence.
            try
            {
                var snap = await SkillsClient.GetSnapshotAsync();
                _pinnedSnapshotId = snap.Id;
            }
            catch
            {
                // Snapshot endpoint may be offline (Petey K-1b not yet shipped) — banner stays quiet.
            }

            var list = await SkillsClient.ListAsync();
            _skills = list.OrderBy(s => s.Name, StringComparer.Ordinal).ToList();

            // Agent names: union of (a) agents already referenced by any skill's EnabledByAgent
            // and (b) all configured agent profiles. Without (b) the picker stays empty on a
            // fresh install, which makes per-agent enablement impossible to trigger from the UI.
            var fromSkills = _skills.SelectMany(s => s.EnabledByAgent.Keys);
            IEnumerable<string> fromProfiles = Array.Empty<string>();
            try
            {
                var profiles = await JobsClient.GetAgentProfilesAsync();
                fromProfiles = profiles.Select(p => p.Name);
            }
            catch
            {
                // Agent-profile endpoint may be unreachable; degrade to skills-only set.
            }
            _agentNames = fromSkills
                .Concat(fromProfiles)
                .Where(a => !string.IsNullOrWhiteSpace(a))
                .Distinct(StringComparer.Ordinal)
                .OrderBy(a => a, StringComparer.Ordinal)
                .ToList();
            _allSources = _skills
                .Select(s => s.Source)
                .Where(s => !string.IsNullOrEmpty(s))
                .Distinct(StringComparer.Ordinal)
                .OrderBy(s => s, StringComparer.Ordinal)
                .ToList();
            ApplyFilter();
        }
        catch (SkillsClientException ex)
        {
            _pageError = ex.Reason;
        }
        catch (Exception ex)
        {
            _pageError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override void OnParametersSet() => ApplyFilter();

    private void ApplyFilter()
    {
        IEnumerable<SkillDto> q = _skills;
        q = q.Where(s => string.Equals(s.Layer, _activeTab, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var needle = _search.Trim();
            q = q.Where(s =>
                s.Name.Contains(needle, StringComparison.OrdinalIgnoreCase)
                || (s.Description ?? "").Contains(needle, StringComparison.OrdinalIgnoreCase)
                || (s.Source ?? "").Contains(needle, StringComparison.OrdinalIgnoreCase));
        }
        if (!string.IsNullOrEmpty(_sourceFilter))
        {
            q = q.Where(s => string.Equals(s.Source, _sourceFilter, StringComparison.Ordinal));
        }
        if (_enabledFilter == "enabled")
        {
            q = q.Where(s => s.EnabledByAgent.Any(kv => kv.Value));
        }
        else if (_enabledFilter == "disabled")
        {
            q = q.Where(s => s.EnabledByAgent.All(kv => !kv.Value));
        }
        _filtered = q.ToList();
    }

    private int CountFor(string layer) =>
        _skills.Count(s => string.Equals(s.Layer, layer, StringComparison.OrdinalIgnoreCase));

    private void ShowCreate() => _showCreate = true;
    private void HideCreate() => _showCreate = false;

    private void ShowImport() => _showImport = true;
    private void HideImport() => _showImport = false;

    private void SelectTab(string key)
    {
        _activeTab = key;
        ApplyFilter();
    }

    private async Task OnCreatedAsync(SkillDto created)
    {
        _showCreate = false;

        // Switch to the tab the new skill landed in and clear filters so the new
        // row is guaranteed visible — Bruno reported the row appeared "missing"
        // after Create until he switched tabs.
        _activeTab = string.IsNullOrWhiteSpace(created?.Layer) ? "installed" : created!.Layer;
        _search = string.Empty;
        _sourceFilter = string.Empty;
        _enabledFilter = "any";

        await LoadAsync();
        StateHasChanged();
    }

    private void OpenDrawer(SkillDto skill)
    {
        _drawerSkillName = skill.Name;
        _showDrawer = true;
    }

    private void HideDrawer()
    {
        _showDrawer = false;
        _drawerSkillName = null;
    }

    private async Task DeleteAsync(SkillDto skill)
    {
        if (!string.Equals(skill.Layer, "installed", StringComparison.OrdinalIgnoreCase)) return;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Delete skill '{skill.Name}'? This cannot be undone.");
        if (!confirmed) return;

        try
        {
            await SkillsClient.DeleteAsync(skill.Name);
            await LoadAsync();
        }
        catch (SkillsClientException ex)
        {
            _pageError = ex.Reason;
        }
    }

    private async Task OnEnabledChangedAsync((string Skill, string Agent, bool Enabled) e)
    {
        // Lightweight reconcile: re-pull the row's current state by re-listing.
        // Keeping it cheap — full snapshot diff is K-2 territory.
        await LoadAsync();
    }

    private async Task OnImportSuccessAsync(string skillName)
    {
        HideImport();
        _activeTab = "installed";
        _search = string.Empty;
        _sourceFilter = string.Empty;
        _enabledFilter = "any";
        await LoadAsync();
        StateHasChanged();
    }

    private async Task OnImportErrorAsync((string Reason, string? Detail, int StatusCode) error)
    {
        _importError = error;
        StateHasChanged();
    }

    // For ApplyFilter to react to bound-input changes immediately:
    private string SearchProxy
    {
        get => _search;
        set { _search = value; ApplyFilter(); }
    }
}
