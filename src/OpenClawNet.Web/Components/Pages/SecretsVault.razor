@page "/secrets-vault"
@rendermode InteractiveServer
@using OpenClawNet.Web.Models.Secrets
@using OpenClawNet.Web.Services
@inject SecretsVaultClient SecretsVaultClient

<PageTitle>OpenClaw .NET - Secrets Vault</PageTitle>

<h3><span class="bi bi-shield-lock me-2" aria-hidden="true"></span>Secrets Vault</h3>
<p class="text-muted">Manage encrypted secrets, versions, recovery, purge, and audit-chain verification.</p>

@if (_error is not null)
{
    <div class="alert alert-danger py-2 small" data-testid="vault-error">@_error</div>
}
@if (_message is not null)
{
    <div class="alert alert-success py-2 small" data-testid="vault-success">@_message</div>
}

<div class="row g-3 mb-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Secret Templates</div>
            <div class="card-body">
                <p class="text-muted small mb-3">Use templates to add multiple related secrets at once.</p>
                
                @if (!_showTemplateForm)
                {
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-primary" data-testid="vault-template-azureopenai" @onclick="ShowAzureOpenAITemplate" disabled="@_busy">
                            <span class="bi bi-plus-circle me-1"></span>Azure OpenAI
                        </button>
                    </div>
                }
                else
                {
                    <div class="mb-2">
                        <strong>@_currentTemplate</strong>
                        <button class="btn btn-sm btn-link float-end" @onclick="CancelTemplate" disabled="@_busy">Cancel</button>
                    </div>
                    
                    @if (_currentTemplate == "AzureOpenAI")
                    {
                        <div class="mb-2">
                            <label class="form-label">Endpoint <span class="text-danger">*</span></label>
                            <input class="form-control" data-testid="vault-template-endpoint" placeholder="https://your-resource.openai.azure.com/" @bind="_templateEndpoint" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Model Deployment Name <span class="text-danger">*</span></label>
                            <input class="form-control" data-testid="vault-template-modelid" placeholder="gpt-4" @bind="_templateModelId" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">API Key <span class="text-danger">*</span></label>
                            <input class="form-control" data-testid="vault-template-apikey" type="password" placeholder="••••••••" @bind="_templateApiKey" />
                        </div>
                        <button class="btn btn-primary" data-testid="vault-template-save" @onclick="SaveTemplateAsync" disabled="@_busy">Save Azure OpenAI Secrets</button>
                    }
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Create / Update Secret</div>
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label">Name</label>
                    <input class="form-control" data-testid="vault-name" @bind="_name" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Value</label>
                    <input class="form-control" data-testid="vault-value" type="password" @bind="_value" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <input class="form-control" data-testid="vault-description" @bind="_description" />
                </div>
                <button class="btn btn-primary" data-testid="vault-save" @onclick="SaveSecretAsync" disabled="@_busy">Save Secret</button>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header">Lifecycle Actions</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Secret name</label>
                        <input class="form-control" data-testid="vault-action-name" @bind="_actionName" />
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Rotate new value</label>
                        <input class="form-control" data-testid="vault-rotate-value" type="password" @bind="_rotateValue" />
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-primary" data-testid="vault-rotate" @onclick="RotateAsync" disabled="@_busy">Rotate</button>
                    <button class="btn btn-outline-warning" data-testid="vault-recover" @onclick="RecoverAsync" disabled="@_busy">Recover</button>
                    <button class="btn btn-outline-danger" data-testid="vault-purge" @onclick="PurgeAsync" disabled="@_busy">Purge</button>
                    <button class="btn btn-outline-secondary" data-testid="vault-audit-verify" @onclick="VerifyAuditAsync" disabled="@_busy">Verify Audit</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Secrets</span>
        <button class="btn btn-sm btn-outline-secondary" data-testid="vault-refresh" @onclick="LoadAsync" disabled="@_busy">Refresh</button>
    </div>
    <div class="card-body">
        @if (_busy && _secrets.Count == 0)
        {
            <div class="text-muted"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading secrets…</div>
        }
        else if (_secrets.Count == 0)
        {
            <div class="text-muted">No secrets found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Updated</th>
                            <th>Versions</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var secret in _secrets)
                    {
                        <tr data-testid="vault-row-@secret.Name">
                            <td>@secret.Name</td>
                            <td>@(secret.Description ?? "—")</td>
                            <td>@secret.UpdatedAt.ToLocalTime().ToString("g")</td>
                            <td>
                                @if (_versions.TryGetValue(secret.Name, out var versions))
                                {
                                    <span data-testid="vault-versions-@secret.Name">@string.Join(", ", versions)</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary me-1"
                                        data-testid="vault-load-versions-@secret.Name"
                                        @onclick="() => LoadVersionsAsync(secret.Name)"
                                        disabled="@_busy">
                                    Versions
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        data-testid="vault-delete-@secret.Name"
                                        @onclick="() => DeleteAsync(secret.Name)"
                                        disabled="@_busy">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private readonly List<SecretSummaryDto> _secrets = [];
    private readonly Dictionary<string, IReadOnlyList<int>> _versions = new(StringComparer.Ordinal);

    private bool _busy;
    private string? _error;
    private string? _message;

    private string _name = string.Empty;
    private string _value = string.Empty;
    private string? _description;
    private string _actionName = string.Empty;
    private string _rotateValue = string.Empty;

    // Template fields
    private bool _showTemplateForm;
    private string _currentTemplate = string.Empty;
    private string _templateEndpoint = string.Empty;
    private string _templateModelId = string.Empty;
    private string _templateApiKey = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await RunAsync(async () =>
        {
            await ReloadSecretsAsync();
            _message = null;
        });
    }

    private async Task SaveSecretAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_value))
        {
            _error = "Name and value are required.";
            return;
        }

        await RunAsync(async () =>
        {
            await SecretsVaultClient.SetAsync(_name.Trim(), new SecretWriteRequest(_value, _description));
            _message = $"Secret '{_name.Trim()}' saved.";
            _error = null;
            _actionName = _name.Trim();
            _value = string.Empty;
            await ReloadSecretsAsync();
        });
    }

    private async Task RotateAsync()
    {
        if (string.IsNullOrWhiteSpace(_actionName) || string.IsNullOrWhiteSpace(_rotateValue))
        {
            _error = "Secret name and rotate value are required.";
            return;
        }

        await RunAsync(async () =>
        {
            await SecretsVaultClient.RotateAsync(_actionName.Trim(), new SecretRotateRequest(_rotateValue));
            _message = $"Secret '{_actionName.Trim()}' rotated.";
            _error = null;
            _rotateValue = string.Empty;
            _versions[_actionName.Trim()] = await SecretsVaultClient.ListVersionsAsync(_actionName.Trim());
            await ReloadSecretsAsync();
        });
    }

    private async Task DeleteAsync(string name)
    {
        await RunAsync(async () =>
        {
            await SecretsVaultClient.DeleteAsync(name);
            _message = $"Secret '{name}' deleted.";
            _error = null;
            _versions.Remove(name);
            await ReloadSecretsAsync();
        });
    }

    private async Task RecoverAsync()
    {
        if (string.IsNullOrWhiteSpace(_actionName))
        {
            _error = "Secret name is required.";
            return;
        }

        await RunAsync(async () =>
        {
            await SecretsVaultClient.RecoverAsync(_actionName.Trim());
            _message = $"Secret '{_actionName.Trim()}' recovered.";
            _error = null;
            await ReloadSecretsAsync();
        });
    }

    private async Task PurgeAsync()
    {
        if (string.IsNullOrWhiteSpace(_actionName))
        {
            _error = "Secret name is required.";
            return;
        }

        await RunAsync(async () =>
        {
            await SecretsVaultClient.PurgeAsync(_actionName.Trim());
            _message = $"Secret '{_actionName.Trim()}' purged.";
            _error = null;
            _versions.Remove(_actionName.Trim());
            await ReloadSecretsAsync();
        });
    }

    private async Task VerifyAuditAsync()
    {
        await RunAsync(async () =>
        {
            var valid = await SecretsVaultClient.VerifyAuditChainAsync();
            _message = valid
                ? "Audit chain is valid."
                : "Audit chain verification failed.";
            _error = null;
        });
    }

    private async Task LoadVersionsAsync(string name)
    {
        await RunAsync(async () =>
        {
            _versions[name] = await SecretsVaultClient.ListVersionsAsync(name);
            _message = $"Loaded versions for '{name}'.";
            _error = null;
        });
    }

    private async Task RunAsync(Func<Task> action)
    {
        _busy = true;
        try
        {
            await action();
        }
        catch (HttpRequestException ex)
        {
            _error = ex.Message;
            _message = null;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ReloadSecretsAsync()
    {
        _secrets.Clear();
        var items = await SecretsVaultClient.ListAsync();
        _secrets.AddRange(items.OrderBy(s => s.Name, StringComparer.OrdinalIgnoreCase));
    }

    private void ShowTemplate(string templateName)
    {
        _showTemplateForm = true;
        _currentTemplate = templateName;
        _templateEndpoint = string.Empty;
        _templateModelId = string.Empty;
        _templateApiKey = string.Empty;
        _error = null;
        _message = null;
    }

    private void ShowAzureOpenAITemplate()
    {
        ShowTemplate("AzureOpenAI");
    }

    private void CancelTemplate()
    {
        _showTemplateForm = false;
        _currentTemplate = string.Empty;
        _templateEndpoint = string.Empty;
        _templateModelId = string.Empty;
        _templateApiKey = string.Empty;
    }

    private async Task SaveTemplateAsync()
    {
        if (_currentTemplate == "AzureOpenAI")
        {
            // Validate required fields
            if (string.IsNullOrWhiteSpace(_templateEndpoint))
            {
                _error = "Azure OpenAI Endpoint is required.";
                return;
            }
            if (string.IsNullOrWhiteSpace(_templateModelId))
            {
                _error = "Model Deployment Name is required.";
                return;
            }
            if (string.IsNullOrWhiteSpace(_templateApiKey))
            {
                _error = "API Key is required.";
                return;
            }

            await RunAsync(async () =>
            {
                // Save the three secrets atomically using the template endpoint
                var secrets = new Dictionary<string, string>
                {
                    ["AzureOpenAI_Endpoint"] = _templateEndpoint.Trim(),
                    ["AzureOpenAI_ModelId"] = _templateModelId.Trim(),
                    ["AzureOpenAI_ApiKey"] = _templateApiKey.Trim()
                };

                await SecretsVaultClient.ApplyTemplateAsync("AzureOpenAI", secrets);

                _message = "Azure OpenAI secrets saved successfully.";
                _error = null;
                
                // Clear template form and return to button view
                CancelTemplate();
                
                await ReloadSecretsAsync();
            });
        }
    }
}
