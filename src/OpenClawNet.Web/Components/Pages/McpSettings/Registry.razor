@page "/settings/mcp/registry"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using OpenClawNet.Web.Components.Pages.McpSettings
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject ILogger<Registry> Logger

<PageTitle>OpenClaw .NET - MCP Registry</PageTitle>

<h3>Browse the MCP Registry <span class="badge bg-info">📋 Official Registry</span></h3>
<p class="text-muted small">Search the public registry at <code>registry.modelcontextprotocol.io</code>.</p>

<div class="d-flex gap-2 mb-3">
    <input class="form-control" placeholder="Search MCP servers (e.g. github, fetch, memory)" @bind="_query" @bind:event="oninput" @onkeydown="OnKeyDown" />
    <button class="btn btn-primary" @onclick="@(() => SearchAsync(null))" disabled="@_loading">Search</button>
    <button class="btn btn-outline-secondary" @onclick="@(() => Nav.NavigateTo("/settings/mcp"))">Back</button>
</div>

@if (_loading)
{
    <div class="text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Searching…</div>
}
else if (_unreachable)
{
    <div class="alert alert-warning py-2 small">
        Registry unreachable. You can still
        <a href="/settings/mcp/new">add servers manually</a>.
    </div>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger py-2 small">@_error</div>
}
else if (_results.Count == 0 && _searched)
{
    <div class="alert alert-info">No results.</div>
}
else if (_results.Count > 0)
{
    <div class="list-group">
        @foreach (var r in _results)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="mb-1"><code>@r.Name</code> <span class="badge bg-light text-dark border">@r.Transport</span></h6>
                        <p class="mb-1 small text-muted">@r.Description</p>
                        @if (!string.IsNullOrEmpty(r.SuggestedCommand))
                        {
                            <code class="small">@r.SuggestedCommand @string.Join(' ', r.SuggestedArgs)</code>
                        }
                        else if (!string.IsNullOrEmpty(r.SuggestedUrl))
                        {
                            <code class="small">@r.SuggestedUrl</code>
                        }
                    </div>
                    <button class="btn btn-sm btn-primary" @onclick="() => Install(r)">Install</button>
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(_nextCursor))
    {
        <div class="text-center mt-3">
            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => SearchAsync(_nextCursor))" disabled="@_loading">
                Load more…
            </button>
        </div>
    }
}

@code {
    private string _query = string.Empty;
    private bool _loading;
    private bool _searched;
    private bool _unreachable;
    private string? _error;
    private List<McpDtos.RegistryEntry> _results = new();
    private string? _nextCursor;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync(null);
    }

    private async Task SearchAsync(string? cursor)
    {
        _loading = true; _error = null; _unreachable = false;
        if (cursor is null) _results = new();
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var url = $"/api/mcp/registry/search?q={Uri.EscapeDataString(_query ?? string.Empty)}";
            if (!string.IsNullOrEmpty(cursor)) url += $"&cursor={Uri.EscapeDataString(cursor)}";
            var resp = await http.GetAsync(url);

            if ((int)resp.StatusCode == 502)
            {
                _unreachable = true;
                return;
            }
            resp.EnsureSuccessStatusCode();
            var result = await resp.Content.ReadFromJsonAsync<McpDtos.RegistrySearchResult>();
            if (result is not null)
            {
                _results.AddRange(result.Entries);
                _nextCursor = result.NextCursor;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Registry search failed.");
            _unreachable = true;
        }
        finally
        {
            _loading = false;
            _searched = true;
        }
    }

    private void Install(McpDtos.RegistryEntry r)
    {
        var qs = new List<string>
        {
            $"PrefillName={Uri.EscapeDataString(r.Name)}",
            $"PrefillTransport={Uri.EscapeDataString(r.Transport)}",
        };
        if (!string.IsNullOrEmpty(r.SuggestedCommand))
            qs.Add($"PrefillCommand={Uri.EscapeDataString(r.SuggestedCommand)}");
        if (r.SuggestedArgs.Length > 0)
            qs.Add($"PrefillArgs={Uri.EscapeDataString(string.Join('\u001f', r.SuggestedArgs))}");
        if (!string.IsNullOrEmpty(r.SuggestedUrl))
            qs.Add($"PrefillUrl={Uri.EscapeDataString(r.SuggestedUrl)}");

        Nav.NavigateTo("/settings/mcp/new?" + string.Join('&', qs));
    }
}
