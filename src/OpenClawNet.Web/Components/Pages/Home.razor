@page "/"
@using System.Text.Json
@inject IConfiguration Configuration
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>OpenClawNet - AI Agent Platform</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    @* Hero Section *@
    <MudPaper Elevation="0" Class="pa-8 mb-6 text-center" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 16px;">
        <MudText Typo="Typo.h2" GutterBottom="true" Class="fw-bold">
            🦞 OpenClawNet
        </MudText>
        <MudText Typo="Typo.h5" Class="mb-4" Style="opacity: 0.95;">
            AI Agent Platform for Intelligent Automation
        </MudText>
        <MudText Typo="Typo.body1" Class="mb-5" Style="max-width: 600px; margin: 0 auto; opacity: 0.9;">
            Schedule jobs, run chat sessions, and deliver outputs across multiple channels — all powered by AI agents with tool-use capabilities
        </MudText>
        <MudStack Row="true" Justify="Justify.Center" Spacing="3">
            <MudButton Variant="Variant.Filled" Color="Color.Surface" Href="/chat" Size="Size.Large" Class="text-primary">
                <MudIcon Icon="@Icons.Material.Filled.Chat" Class="me-2" />
                Start Chatting
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Surface" Href="/jobs/templates" Size="Size.Large">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="me-2" />
                Explore Templates
            </MudButton>
        </MudStack>
    </MudPaper>

    @* Feature Highlights *@
    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-4 text-center">
        ✨ What's New in Phase 2
    </MudText>
    <MudGrid Class="mb-6">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-5" Style="height: 100%; border-left: 4px solid #667eea;">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
                <MudText Typo="Typo.h6" GutterBottom="true">Audit Trails</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Track every job state change, tool approval, and adapter delivery with comprehensive audit logs
                </MudText>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/audit" Size="Size.Small">
                    View Audit Logs →
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-5" Style="height: 100%; border-left: 4px solid #764ba2;">
                <MudIcon Icon="@Icons.Material.Filled.SendToMobile" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                <MudText Typo="Typo.h6" GutterBottom="true">Multi-Channel Delivery</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Send job outputs to Teams, Slack, webhooks, or custom channels — all configured per job
                </MudText>
                <MudButton Variant="Variant.Text" Color="Color.Secondary" Href="/jobs" Size="Size.Small">
                    Configure Channels →
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-5" Style="height: 100%; border-left: 4px solid #f093fb;">
                <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Size="Size.Large" Color="Color.Tertiary" Class="mb-3" />
                <MudText Typo="Typo.h6" GutterBottom="true">Agent Profiles</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Create and manage AI agent profiles with custom instructions, tools, and model settings
                </MudText>
                <MudButton Variant="Variant.Text" Color="Color.Tertiary" Href="/agent-profiles" Size="Size.Small">
                    Manage Profiles →
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Featured Demo Templates *@
    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-4 text-center">
        🚀 Featured Demo Templates
    </MudText>
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Class="h-100">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.Calculate" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Calculator Agent</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Perform mathematical calculations using natural language queries
                    </MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/jobs/templates" Size="Size.Small">
                        Use Template
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Class="h-100">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.Cloud" Color="Color.Secondary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Weather Reporter</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Get weather forecasts and create scheduled reports for multiple cities
                    </MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Href="/jobs/templates" Size="Size.Small">
                        Use Template
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Class="h-100">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Tertiary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Web Researcher</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Search the web and compile research reports on any topic
                    </MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Tertiary" Href="/jobs/templates" Size="Size.Small">
                        Use Template
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* Quick Start Guide *@
    <MudPaper Elevation="1" Class="pa-5 mb-6" Style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">
        <MudText Typo="Typo.h5" GutterBottom="true" Class="fw-bold">
            <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Class="me-2" />
            Quick Start Guide
        </MudText>
        <MudText Typo="Typo.body1" Class="mb-3">
            Get started with OpenClawNet in just a few steps:
        </MudText>
        <MudList T="string" Dense="true">
            <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                <MudText Typo="Typo.body2"><strong>1. Configure Model Providers:</strong> Set up Azure OpenAI, Ollama, or other AI providers in <MudLink Href="/model-providers" Color="Color.Primary">Settings</MudLink></MudText>
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                <MudText Typo="Typo.body2"><strong>2. Create Agent Profiles:</strong> Define AI agents with custom instructions in <MudLink Href="/agent-profiles" Color="Color.Primary">Agent Profiles</MudLink></MudText>
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                <MudText Typo="Typo.body2"><strong>3. Try a Template:</strong> Browse <MudLink Href="/jobs/templates" Color="Color.Primary">Job Templates</MudLink> for ready-to-use examples</MudText>
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                <MudText Typo="Typo.body2"><strong>4. Start Chatting:</strong> Test your agents in <MudLink Href="/chat" Color="Color.Primary">Chat</MudLink> mode</MudText>
            </MudListItem>
        </MudList>
    </MudPaper>

    @* Recent Job Output Widget *@
    <MudText Typo="Typo.h5" GutterBottom="true" Class="mb-4">
        📋 Recent Job Output
    </MudText>

    @if (_isLoading)
    {
        <MudGrid>
            @for (int i = 0; i < 5; i++)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard>
                        <MudCardContent>
                            <MudSkeleton SkeletonType="SkeletonType.Text" Height="30px" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Height="20px" Class="mt-2" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Height="20px" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            @_error
        </MudAlert>
    }
    else if (_recentJobs is null || _recentJobs.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            No job output yet — run a job to see results here.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var job in _recentJobs)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Class="cursor-pointer hover-elevation" @onclick="() => OpenJobChannel(job.JobId)">
                        <MudCardContent>
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.subtitle1" Class="fw-bold text-truncate">
                                    @job.JobName
                                </MudText>
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                @GetRelativeTime(job.LastActivityUtc)
                            </MudText>
                            <div class="d-flex align-center gap-2">
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Description">
                                    @job.TotalArtifacts @(job.TotalArtifacts == 1 ? "artifact" : "artifacts")
                                </MudChip>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        @if (!string.IsNullOrEmpty(_channelsBaseUrl))
        {
            <div class="text-center mt-4">
                <MudLink Href="@($"{_channelsBaseUrl}/channels")" Target="_blank" Typo="Typo.body1">
                    View all output channels →
                </MudLink>
            </div>
        }
    }
</MudContainer>

<style>
    .cursor-pointer {
        cursor: pointer;
    }
    
    .hover-elevation {
        transition: box-shadow 0.3s ease-in-out;
    }
    
    .hover-elevation:hover {
        box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important;
    }
    
    .text-truncate-multiline {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {
    private List<JobOutputItem>? _recentJobs;
    private bool _isLoading = true;
    private string? _error;
    private string? _channelsBaseUrl;
    private PeriodicTimer? _refreshTimer;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _channelsBaseUrl = Configuration["Channels:BaseUrl"];
        _cts = new CancellationTokenSource();
        
        await LoadJobOutputAsync();
        
        // Start polling every 10 seconds
        _refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        _ = Task.Run(async () =>
        {
            while (await _refreshTimer.WaitForNextTickAsync(_cts.Token))
            {
                await InvokeAsync(async () =>
                {
                    await LoadJobOutputAsync();
                    StateHasChanged();
                });
            }
        });
    }

    private async Task LoadJobOutputAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var response = await client.GetAsync("/api/channels");
            
            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _error = "Job output feature coming soon — endpoint not yet available.";
                _recentJobs = null;
            }
            else if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var items = JsonSerializer.Deserialize<List<JobOutputItem>>(json, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
                
                _recentJobs = items?.Take(5).ToList();
                _error = null;
            }
            else
            {
                _error = $"Failed to load job output (HTTP {(int)response.StatusCode}).";
                _recentJobs = null;
            }
        }
        catch (HttpRequestException)
        {
            _error = "Job output service unavailable — check that the Gateway is running.";
            _recentJobs = null;
        }
        catch (Exception ex)
        {
            _error = $"Error loading job output: {ex.Message}";
            _recentJobs = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenJobChannel(Guid jobId)
    {
        if (!string.IsNullOrEmpty(_channelsBaseUrl))
        {
            // Open in a new tab instead of replacing the current page.
            await JS.InvokeVoidAsync("open", $"{_channelsBaseUrl}/channels/{jobId}", "_blank", "noopener");
        }
    }

    private string GetRelativeTime(DateTime timestamp)
    {
        var now = DateTime.UtcNow;
        var diff = now - timestamp;

        if (diff.TotalSeconds < 60)
            return "just now";
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours} hour{((int)diff.TotalHours != 1 ? "s" : "")} ago";
        if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays} day{((int)diff.TotalDays != 1 ? "s" : "")} ago";
        
        return timestamp.ToLocalTime().ToString("MMM d, yyyy");
    }

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _refreshTimer?.Dispose();
    }

    /// <summary>
    /// Maps to ChannelSummaryDto from Gateway /api/channels endpoint.
    /// Fields: JobId, JobName, LastActivityUtc, TotalArtifacts
    /// </summary>
    private class JobOutputItem
    {
        public Guid JobId { get; set; }
        public string JobName { get; set; } = string.Empty;
        public DateTime LastActivityUtc { get; set; }
        public int TotalArtifacts { get; set; }
    }
}
